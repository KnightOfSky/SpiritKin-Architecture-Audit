{
  "schema_version": "spiritkin.game_adapter.v1",
  "id": "game.local_collect_demo",
  "label": "SpiritKin Local Collect Demo",
  "allowed_origins": [
    "http://127.0.0.1:*",
    "http://localhost:*"
  ],
  "allowed_paths": [
    "/game_automation_demo.html"
  ],
  "title_pattern": "^SpiritKin Automation Demo$",
  "expected_scenes": [
    "collect_run"
  ],
  "allowed_actions": [
    "move_left",
    "move_right",
    "move_up",
    "move_down",
    "collect"
  ],
  "max_actions_per_second": 5,
  "requires_focus": true,
  "risk": "high",
  "stop_conditions": [
    "focus_lost",
    "unknown_scene",
    "kill_switch",
    "rate_limit",
    "goal_complete"
  ]
}
