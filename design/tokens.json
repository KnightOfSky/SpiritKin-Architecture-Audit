    "rules": [
      "Protect information architecture and behavior; allow minimal layout changes for accessibility and native platform requirements.",
      "Night uses low-chroma warm charcoal surfaces with copper identity accents.",
      "Light uses cool daylight surfaces with blue structure and copper identity accents.",
      "Semantic status colors must use foreground/background pairs and must not rely on color alone.",
      "All ordinary text pairs must reach WCAG AA 4.5:1; non-text control boundaries and focus indicators must reach 3:1."
    ]
