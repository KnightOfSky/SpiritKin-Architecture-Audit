{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spiritkin.local/schemas/design-tokens-v4.json",
  "title": "SpiritKin Design Tokens v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "meta", "themes", "contrast_checks", "typography", "motion", "mapping"],
  "properties": {
    "$schema": {"const": "./tokens.schema.json"},
    "meta": {
      "type": "object",
      "required": ["name", "version", "updated", "authority", "rules"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"const": 4},
        "updated": {"type": "string", "format": "date"},
        "authority": {"type": "string", "minLength": 1},
        "visual_reference": {"type": "string"},
        "rules": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      }
    },
    "themes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dark", "light"],
      "properties": {
        "dark": {"$ref": "#/$defs/theme"},
        "light": {"$ref": "#/$defs/theme"}
      }
    },
    "contrast_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["foreground", "background", "minimum"],
        "properties": {
          "foreground": {"type": "string"},
          "background": {"type": "string"},
          "minimum": {"type": "number", "minimum": 3}
        }
      }
    },
    "typography": {"type": "object", "additionalProperties": {"type": "string"}},
    "motion": {
      "type": "object",
      "required": ["fast_ms", "normal_ms", "slow_ms", "reduced_motion"],
      "properties": {
        "fast_ms": {"type": "integer", "minimum": 0, "maximum": 250},
        "normal_ms": {"type": "integer", "minimum": 0, "maximum": 250},
        "slow_ms": {"type": "integer", "minimum": 0, "maximum": 300},
        "reduced_motion": {"type": "string"}
      }
    },
    "mapping": {"type": "object", "additionalProperties": {"type": "string"}}
  },
  "$defs": {
    "colorToken": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hex", "oklch"],
      "properties": {
        "hex": {"type": "string", "pattern": "^#[0-9A-F]{6}$"},
        "oklch": {"type": "string", "pattern": "^oklch\\([0-9.]+% [0-9.]+ [0-9.]+\\)$"}
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/colorToken"},
      "required": [
        "canvas", "surface", "surface-2", "surface-3", "line", "control-border",
        "text", "muted", "faint", "accent", "accent-2", "on-accent", "copper", "on-copper",
        "success-fg", "success-bg", "warning-fg", "warning-bg", "danger-fg", "danger-bg",
        "info-fg", "info-bg", "focus-ring"
      ]
    }
  }
}
