# Public HTTPS hostname served by Caddy. Use a real DNS name in cloud.
CADDY_HOST=control.example.com
HTTP_BIND=80
HTTPS_BIND=443

# Keep the raw Python receiver private to the VM by default.
CONTROL_PLANE_DIRECT_BIND=127.0.0.1:8791

# MinIO console is for operator diagnostics. Keep it private unless fronted by auth.
MINIO_CONSOLE_BIND=127.0.0.1:9001

# Production mode requires management, Android, Worker, and iOS terminal tokens.
SPIRITKIN_PRODUCTION_MODE=1
SPIRITKIN_MANAGEMENT_TOKEN=replace-with-a-long-random-management-token
SPIRITKIN_WORKER_MANIFEST_SIGNING_SECRET=replace-with-a-long-random-worker-manifest-secret

# Artifact storage. The compose stack defaults to internal MinIO.
SPIRITKIN_ARTIFACT_BACKEND=s3
SPIRITKIN_ARTIFACT_S3_ENDPOINT_URL=http://minio:9000
SPIRITKIN_ARTIFACT_S3_BUCKET=spiritkin-artifacts
SPIRITKIN_ARTIFACT_S3_REGION=us-east-1
SPIRITKIN_ARTIFACT_S3_PREFIX=prod
SPIRITKIN_ARTIFACT_S3_PUBLIC_BASE_URL=
SPIRITKIN_ARTIFACT_S3_PATH_STYLE=1

# S3 credentials used by the control plane and by the bundled MinIO service.
AWS_ACCESS_KEY_ID=spiritkin-minio
AWS_SECRET_ACCESS_KEY=replace-with-at-least-16-random-characters
