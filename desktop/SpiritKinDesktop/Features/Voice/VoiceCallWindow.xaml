<Window x:Class="SpiritKinDesktop.VoiceCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpiritKin 语音通话"
        Width="520"
        Height="680"
        MinWidth="440"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource FantasyCanvasBrush}"
        Foreground="{DynamicResource FantasyTextBrush}"
        FontFamily="{StaticResource UiFontFamily}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="VoiceIconButton" TargetType="Button" BasedOn="{StaticResource TinyButton}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="18" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="154" />
            <RowDefinition Height="*" />
            <RowDefinition Height="72" />
            <RowDefinition Height="74" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{DynamicResource FantasyLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="语音通话" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock x:Name="ConnectionDetailText"
                               Text="本地语音链"
                               FontSize="11"
                               Foreground="{DynamicResource FantasyMutedBrush}" />
                </StackPanel>
                <TextBlock x:Name="ElapsedText"
                           Grid.Column="1"
                           Text="00:00"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="12"
                           Foreground="{DynamicResource FantasyMutedBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18,12">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="58"
                        Height="58"
                        CornerRadius="29"
                        Background="{DynamicResource FantasyInfoWashBrush}"
                        BorderBrush="{DynamicResource FantasyFocusRingBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="StateIconText"
                               Text="&#xE720;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="25"
                               Foreground="{DynamicResource FantasyInfoBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="StatusText"
                           Text="正在连接"
                           Margin="0,12,0,0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center" />
                <TextBlock x:Name="StatusDetailText"
                           Text=""
                           Margin="0,5,0,0"
                           MaxWidth="420"
                           FontSize="12"
                           Foreground="{DynamicResource FantasyMutedBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Margin="18,0"
                BorderBrush="{DynamicResource FantasyLineBrush}"
                BorderThickness="1,1,1,0"
                Background="{DynamicResource FantasySurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer x:Name="TranscriptScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,12">
                    <StackPanel x:Name="TranscriptPanel" />
                </ScrollViewer>
                <Border Grid.Row="1"
                        Padding="16,9"
                        Background="{DynamicResource FantasyInputBrush}"
                        BorderBrush="{DynamicResource FantasyLineBrush}"
                        BorderThickness="0,1,0,0">
                    <TextBlock x:Name="PartialTranscriptText"
                               Text=""
                               MinHeight="18"
                               FontSize="12"
                               Foreground="{DynamicResource FantasyMutedBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="18,0"
                Padding="14,10"
                BorderBrush="{DynamicResource FantasyLineBrush}"
                BorderThickness="1,1,1,0"
                Background="{DynamicResource FantasySurfaceBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="麦克风"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource FantasyMutedBrush}" />
                <ComboBox x:Name="DeviceBox"
                          Grid.Column="1"
                          MinHeight="32"
                          VerticalContentAlignment="Center"
                          SelectionChanged="DeviceBox_SelectionChanged"
                          AutomationProperties.Name="麦克风设备" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                BorderBrush="{DynamicResource FantasyLineBrush}"
                BorderThickness="0,1,0,0"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="RecoveryActionsPanel"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <Button Content="重试" Click="RetryButton_Click" Style="{StaticResource TinyButton}" Margin="0,0,8,0" />
                    <Button Content="回到文字" Click="TextFallbackButton_Click" Style="{StaticResource TinyButton}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="MicToggleButton"
                            Style="{StaticResource VoiceIconButton}"
                            Content="&#xE720;"
                            Click="MicToggleButton_Click"
                            ToolTip="静音麦克风"
                            AutomationProperties.Name="静音麦克风" />
                    <Button x:Name="SpeakerToggleButton"
                            Style="{StaticResource VoiceIconButton}"
                            Content="&#xE767;"
                            Click="SpeakerToggleButton_Click"
                            ToolTip="关闭扬声器"
                            AutomationProperties.Name="关闭扬声器" />
                    <Button Style="{StaticResource VoiceIconButton}"
                            Content="&#xE778;"
                            Foreground="{DynamicResource FantasyDangerBrush}"
                            Click="EndButton_Click"
                            ToolTip="结束通话"
                            AutomationProperties.Name="结束通话" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
