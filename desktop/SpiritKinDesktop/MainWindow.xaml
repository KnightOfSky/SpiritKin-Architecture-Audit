<Window x:Class="SpiritKinDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpiritKinDesktop.Controls"
        xmlns:local="clr-namespace:SpiritKinDesktop"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SpiritKin Desktop"
        Width="1480"
        Height="940"
        MinWidth="1280"
        MinHeight="760"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource FantasyCanvasBrush}"
        Foreground="{DynamicResource FantasyTextBrush}"
        FontFamily="{StaticResource UiFontFamily}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="MusicPlayerRow" Height="0" />
            <RowDefinition x:Name="TerminalRow" Height="0" />
        </Grid.RowDefinitions>

        <controls:WindowTitleBar x:Name="TitleBar"
                                 Grid.Row="0"
                                 shell:WindowChrome.IsHitTestVisibleInChrome="True" />

        <!-- G2 服务健康横幅：看门狗判定后端离线/恢复、连续 401 时显示；默认隐藏，可手动关闭。 -->
        <Border x:Name="ServiceHealthBannerElement"
                Grid.Row="1"
                Panel.ZIndex="15"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Background="{DynamicResource FantasyBannerWarnBgBrush}"
                BorderBrush="{DynamicResource FantasyBannerWarnBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,6">
            <DockPanel LastChildFill="True">
                <Button x:Name="ServiceHealthBannerCloseButton"
                        DockPanel.Dock="Right"
                        Content="×"
                        Width="22"
                        Height="22"
                        Padding="0"
                        FontSize="14"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
                <Button x:Name="ServiceHealthBannerRecoverButton"
                        DockPanel.Dock="Right"
                        Content="恢复"
                        MinWidth="54"
                        Height="24"
                        Padding="10,0"
                        Margin="0,0,8,0"
                        Style="{StaticResource TinyButton}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center" />
                <TextBlock x:Name="ServiceHealthBannerText"
                           Text=""
                           FontSize="12"
                           Foreground="{DynamicResource FantasyBannerWarnTextBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="216" MinWidth="216" MaxWidth="216" />
                <ColumnDefinition x:Name="ChatSplitterColumn" Width="6" />
                <ColumnDefinition x:Name="ChatColumn" Width="*" MinWidth="560" />
                <ColumnDefinition x:Name="RightSplitterColumn" Width="6" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="300" MinWidth="300" MaxWidth="300" />
            </Grid.ColumnDefinitions>

            <controls:WorkspaceSidebarView x:Name="WorkspaceSidebar" Grid.Column="0" />

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Style="{StaticResource WorkspaceSplitter}"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <controls:ChatWorkspaceView x:Name="ChatWorkspace" Grid.Column="2" />

            <GridSplitter Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Style="{StaticResource WorkspaceSplitter}"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <controls:WorkbenchShellView x:Name="WorkbenchShell" Grid.Column="4" />
        </Grid>
        <controls:MusicPlayerBarView x:Name="MusicPlayerBar"
                                     Grid.Row="2"
                                     Visibility="Collapsed" />
        <controls:IntegratedTerminalPanelView x:Name="TerminalPanel"
                                              Grid.Row="3"
                                              Visibility="Collapsed" />

        <!-- Reference parity: 12s night light-flow / 40s day-sky drift. -->
        <Grid Grid.RowSpan="4"
              Panel.ZIndex="10"
              Visibility="Visible"
              IsHitTestVisible="False"
              ClipToBounds="True">
            <Rectangle x:Name="AtelierGlassDriftElement"
                       Margin="-36,-48"
                       Fill="{DynamicResource AtelierGlassDriftBrush}"
                       Opacity="0.22">
                <Rectangle.RenderTransform>
                    <TranslateTransform x:Name="AtelierGlassDriftTransformElement" X="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="AtelierLightFlowPrimaryElement"
                       Fill="{DynamicResource AtelierLightFlowPrimaryBrush}"
                       Opacity="0.35"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="2.2" />
                        <TranslateTransform x:Name="AtelierLightFlowPrimaryTransformElement" />
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="AtelierLightFlowWarningElement"
                       Fill="{DynamicResource AtelierLightFlowWarningBrush}"
                       Opacity="0.35"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.8" />
                        <TranslateTransform x:Name="AtelierLightFlowWarningTransformElement" />
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="AtelierLightFlowSecondaryElement"
                       Fill="{DynamicResource AtelierLightFlowSecondaryBrush}"
                       Opacity="0.35"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.6" />
                        <TranslateTransform x:Name="AtelierLightFlowSecondaryTransformElement" />
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Grid>

        <controls:GlobalSearchOverlayView x:Name="GlobalSearchOverlay"
                                          Grid.RowSpan="4"
                                          Panel.ZIndex="20"
                                          Visibility="Collapsed" />
    </Grid>
</Window>


