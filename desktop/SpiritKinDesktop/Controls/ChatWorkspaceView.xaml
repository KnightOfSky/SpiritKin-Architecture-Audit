<UserControl x:Class="SpiritKinDesktop.Controls.ChatWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SpiritKinDesktop.Controls"
             xmlns:local="clr-namespace:SpiritKinDesktop"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextHintingMode="Auto">
    <UserControl.Resources>
        <Style x:Key="AtelierComposerSendButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AtelierComposerButtonInkBrush}" />
            <Setter Property="Background" Value="{DynamicResource FantasyCopperBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{DynamicResource FantasyPrimaryHoverGradientBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{DynamicResource FantasyPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DrawingBrush x:Key="AtelierFiberPatternBrush"
                      TileMode="Tile"
                      Viewport="0,0,5,5"
                      ViewportUnits="Absolute"
                      Viewbox="0,0,5,5"
                      ViewboxUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing Geometry="M 0,0 L 5,0">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{DynamicResource AtelierFiberBrush}" Thickness="1" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>
<Border Grid.Column="2" Background="{DynamicResource AtelierChatBackgroundBrush}" BorderThickness="0">
            <Grid>
                <Border Background="{StaticResource AtelierFiberPatternBrush}" IsHitTestVisible="False" />
                <Grid x:Name="ChatWorkspacePageElement">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="ChatHeaderRowElement" Height="Auto" MinHeight="65" />
                    <RowDefinition Height="72" />
                    <RowDefinition Height="*" />
                    <RowDefinition x:Name="ChatArtifactsRowElement" Height="Auto" />
                    <RowDefinition x:Name="ChatSplitterRowElement" Height="1" />
                    <RowDefinition x:Name="ChatComposerRowElement" Height="Auto" MinHeight="155" />
                </Grid.RowDefinitions>
                <Border x:Name="ChatHeaderBarElement" Grid.Row="0" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="14,8" Background="Transparent">
                    <Grid>
                        <!-- 标题列用 * 弹性收缩、右侧状态区 Auto 优先占位：否则状态 StackPanel
                             超宽时右对齐溢出会盖住"..."按钮（2026-07-09 实测双工文案与按钮重叠）。 -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="ActiveTitleTextElement" Text="主会话" FontFamily="{StaticResource DisplayFontFamily}" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource FantasyTextBrush}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock x:Name="ActiveMetaTextElement" Text="修订 0" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <WrapPanel x:Name="CollaborationMembersPanelElement" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="ChatActionsButtonElement" Grid.Column="1" Content="..." Width="24" Height="28" Padding="0" MinHeight="28" Style="{StaticResource ComposerMenuButton}" Margin="4,0,8,0" VerticalAlignment="Center" AutomationProperties.Name="会话操作菜单" ToolTip="会话操作" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <CheckBox x:Name="ChatDuplexToggleElement" Content="双工" Foreground="{DynamicResource FantasyMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" Visibility="Collapsed" FocusVisualStyle="{x:Null}" ToolTip="模型互聊（双工）：允许模型之间自动回复，受轮次上限保护" />
                            <TextBlock x:Name="ChatDuplexBalanceTextElement" Text="余额 --" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed" ToolTip="双工轮次余额：模型互聊剩余轮数/上限；“持续”表示不限轮，由硬熔断兜底" />
                            <TextBlock x:Name="SafetyStatusTextElement" Text="安全 --" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <Button x:Name="SafetyStopButtonElement" Content="停止" Width="38" Height="28" MinHeight="28" Padding="0" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource FantasyDangerBrush}" Style="{StaticResource ComposerMenuButton}" Margin="0,0,4,0" AutomationProperties.Name="启用全局安全停止" ToolTip="全局安全停止：阻断工具、工作流、远端和 Skill 执行">
                            </Button>
                            <Button x:Name="SafetyResumeButtonElement" Content="恢复" Width="38" Height="28" MinHeight="28" Padding="0" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource FantasySuccessBrush}" Style="{StaticResource ComposerMenuButton}" Margin="0,0,4,0" AutomationProperties.Name="恢复全局安全执行" ToolTip="恢复全局安全执行：解除安全停止">
                            </Button>
                            <TextBlock x:Name="WsStatusTextElement" Text="实时 --" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock x:Name="PendingTextElement" Text="" Style="{StaticResource StatusPillText}" Background="{DynamicResource FantasyGoldWashBrush}" Foreground="{DynamicResource FantasyWarningBrush}" Visibility="Collapsed" MinWidth="86" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid x:Name="ConfirmBarElement" Grid.Row="1" Width="455" MaxWidth="680" Margin="0,12" HorizontalAlignment="Center" Visibility="Collapsed">
                    <Border BorderBrush="{DynamicResource FantasyCopperBrush}" BorderThickness="3,0,0,0"
                            CornerRadius="3" Background="{DynamicResource FantasyInputBrush}" Padding="7,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="等待确认 / Permission Gate" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource FantasyTextBrush}" />
                                <TextBlock x:Name="ConfirmTextElement" Text="--" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="11.5" TextWrapping="Wrap" Margin="0,3,12,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="CancelButtonElement" Content="取消" Width="58" Height="30" MinHeight="30" Style="{StaticResource TinyButton}" Margin="0,0,8,0" Visibility="Collapsed" />
                                <Button x:Name="ConfirmButtonElement" Content="确认执行" Width="80" Height="30" MinHeight="30" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Width="3"
                            HorizontalAlignment="Left"
                            Margin="0,1"
                            CornerRadius="3,0,0,3"
                            Background="{DynamicResource FantasyCopperBrush}"
                            Style="{StaticResource AtelierBreathingRail}"
                            IsHitTestVisible="False" />
                </Grid>
                <Grid x:Name="QuickChatEmptyPanelElement" Grid.Row="2" Grid.RowSpan="4" Background="Transparent" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="10*" MinWidth="680" MaxWidth="960" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <TextBlock x:Name="EmptyQuickChatTitleTextElement"
                                   Text="今天先处理哪件事？"
                                   FontFamily="{StaticResource DisplayFontFamily}"
                                   Foreground="{DynamicResource FantasyTextBrush}"
                                   FontSize="20"
                                   FontWeight="ExtraBold"
                                   TextAlignment="Center"
                                   Margin="0,0,0,24" />
                        <Border CornerRadius="5,5,0,0" BorderThickness="1" Background="{DynamicResource FantasyInputBrush}" Padding="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource FantasyCardBorderBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource FantasyPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                 <Grid.RowDefinitions>
                                     <RowDefinition Height="Auto" />
                                     <RowDefinition Height="Auto" />
                                     <RowDefinition Height="Auto" />
                                     <RowDefinition Height="32" />
                                </Grid.RowDefinitions>
                                <ItemsControl x:Name="EmptyComposerAttachmentsListElement" Grid.Row="0" ItemTemplate="{StaticResource ComposerAttachmentTemplate}" Margin="14,12,14,0" Visibility="Collapsed">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <Grid Grid.Row="1">
                                    <TextBox x:Name="EmptyPromptBoxElement"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             HorizontalContentAlignment="Stretch"
                                             VerticalScrollBarVisibility="Auto"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource FantasyTextBrush}"
                                             CaretBrush="{DynamicResource FantasyPrimaryBrush}"
                                             Padding="12,8"
                                             FontSize="13"
                                             MinLines="2"
                                             MaxLines="8"
                                             MinHeight="64"
                                             MaxHeight="190" />
                                    <TextBlock Text="描述任务、目标或需要继续的工作"
                                               Foreground="{DynamicResource FantasyHintTextBrush}"
                                               FontSize="12.5"
                                               Margin="13,10,13,0"
                                               VerticalAlignment="Top"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text.Length, ElementName=EmptyPromptBoxElement}" Value="0" />
                                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=EmptyPromptBoxElement}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                 <StackPanel x:Name="EmptyComposerStatusPanelElement" Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,4,12,0" Visibility="Collapsed">
                                     <TextBlock x:Name="EmptyAttachmentStatusTextElement" Text="" Style="{StaticResource MutedText}" VerticalAlignment="Center" Visibility="Collapsed" />
                                     <Button x:Name="EmptyClearPlanButtonElement" Content="× 计划" Height="24" MinHeight="24" Padding="8,0" Margin="6,0,0,0" Style="{StaticResource TinyButton}" Visibility="Collapsed" />
                                     <Button x:Name="EmptyClearGoalButtonElement" Content="× 目标" Height="24" MinHeight="24" Padding="8,0" Margin="6,0,0,0" Style="{StaticResource TinyButton}" Visibility="Collapsed" />
                                 </StackPanel>
                                 <Grid Grid.Row="3" Background="{DynamicResource FantasyListAltBrush}" Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0" LastChildFill="False" ClipToBounds="True" Margin="12,0,8,0">
                                        <Button x:Name="EmptyCollaborationModeButtonElement" Content="模型协作" Height="28" MinHeight="28" Padding="10,0" Style="{StaticResource TinyButton}" DockPanel.Dock="Left" ToolTip="开启模型协作对话" />
                                        <Button x:Name="EmptyWebSearchModeButtonElement" Content="联网检索" Height="28" MinHeight="28" Padding="10,0" Margin="6,0,0,0" Style="{StaticResource TinyButton}" DockPanel.Dock="Left" ToolTip="开启联网检索" />
                                        <Button x:Name="EmptyAttachButtonElement" Content="+" Width="28" Height="28" Padding="0" MinHeight="28" Margin="8,0,0,0" Style="{StaticResource TinyButton}" DockPanel.Dock="Left" AutomationProperties.Name="添加附件" ToolTip="添加附件" />
                                        <Button x:Name="EmptyAgentMentionButtonElement" Content="@" Width="28" Height="28" Padding="0" MinHeight="28" Margin="6,0,0,0" Style="{StaticResource TinyButton}" DockPanel.Dock="Left" AutomationProperties.Name="提及 Agent" ToolTip="@ Agent" />
                                        <Button x:Name="EmptyPermissionButtonElement" Style="{StaticResource ComposerMenuButton}" Margin="6,0,0,0" Foreground="{DynamicResource FantasyWarningBrush}" DockPanel.Dock="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="EmptyPermissionTextElement" Text="完全访问" VerticalAlignment="Center" />
                                                <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                            </StackPanel>
                                        </Button>
                                    </DockPanel>
                                    <!-- @提及预览悬浮气泡（空会话输入框同款）。 -->
                                    <Popup x:Name="EmptyAgentMentionPopupElement" PlacementTarget="{Binding ElementName=EmptyPromptBoxElement}" Placement="Top" HorizontalOffset="8" VerticalOffset="-4" AllowsTransparency="True" StaysOpen="True">
                                        <Border Background="{DynamicResource FantasySurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="10,5">
                                            <TextBlock x:Name="EmptyAgentMentionStatusTextElement" Text="" Style="{StaticResource MutedText}" />
                                        </Border>
                                    </Popup>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button x:Name="EmptyModelButtonElement" Style="{StaticResource ComposerMenuButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="EmptyModelTextElement" Text="自动（主模型）" Foreground="{DynamicResource FantasyTextBrush}" VerticalAlignment="Center" MaxWidth="90" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="EmptyReasoningButtonElement" Style="{StaticResource ComposerMenuButton}" Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="EmptyReasoningTextElement" Text="自动推理" Foreground="{DynamicResource FantasyFaintTextBrush}" VerticalAlignment="Center" MaxWidth="68" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <Button x:Name="EmptySendButtonElement" Content="发送" Width="56" Height="28" Padding="0" MinHeight="28" Grid.Column="2" Margin="8,3,8,3" Style="{StaticResource AtelierComposerSendButton}" ToolTip="发送" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Border CornerRadius="0,0,5,5"
                                Background="Transparent"
                                BorderBrush="{DynamicResource FantasyCardBorderBrush}"
                                BorderThickness="1,0,1,1"
                                Padding="14,8"
                                Margin="0,-1,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="EmptyProjectButtonElement" Style="{StaticResource ComposerMenuButton}" Padding="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="▱" Foreground="{DynamicResource FantasyMutedBrush}" Margin="0,0,7,0" />
                                        <TextBlock x:Name="EmptyProjectHintTextElement" Text="会话" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                        <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="EmptyRuntimeButtonElement" Style="{StaticResource ComposerMenuButton}" Padding="0,2" Margin="18,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="▱" Foreground="{DynamicResource FantasyMutedBrush}" Margin="0,0,7,0" />
                                        <TextBlock x:Name="EmptyRuntimeTextElement" Text="本地工作" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                        <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="EmptyBranchButtonElement" Style="{StaticResource ComposerMenuButton}" Padding="0,2" Margin="18,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⎇" Foreground="{DynamicResource FantasyMutedBrush}" Margin="0,0,7,0" />
                                        <TextBlock x:Name="EmptyBranchTextElement" Text="master" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                        <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                <ListBox x:Name="MessagesListElement" Grid.Row="2" ItemContainerStyle="{StaticResource MessageListItem}" Background="Transparent" BorderThickness="0" Padding="0,28" Margin="0" ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.CacheLength="1" />
                <Border x:Name="TopicAnchorsPanelElement" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Background="Transparent" CornerRadius="9" Padding="1,5" Opacity="0.38" Visibility="Collapsed" ToolTipService.InitialShowDelay="150">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0.38" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ItemsControl x:Name="TopicAnchorsListElement">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button ToolTip="{Binding Preview}" Cursor="Hand" AutomationProperties.Name="{Binding Preview}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" Padding="5,4">
                                                <Ellipse x:Name="AnchorDot" Width="7" Height="7" Fill="{Binding DotBrush}" Opacity="0.45" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="AnchorDot" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                <DoubleAnimation Storyboard.TargetName="AnchorDot" Storyboard.TargetProperty="Width" To="9" Duration="0:0:0.15" />
                                                                <DoubleAnimation Storyboard.TargetName="AnchorDot" Storyboard.TargetProperty="Height" To="9" Duration="0:0:0.15" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="AnchorDot" Storyboard.TargetProperty="Opacity" To="0.45" Duration="0:0:0.15" />
                                                                <DoubleAnimation Storyboard.TargetName="AnchorDot" Storyboard.TargetProperty="Width" To="7" Duration="0:0:0.15" />
                                                                <DoubleAnimation Storyboard.TargetName="AnchorDot" Storyboard.TargetProperty="Height" To="7" Duration="0:0:0.15" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                <Border x:Name="ConversationArtifactsPanelElement" Grid.Row="3" MinHeight="58" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0" Background="Transparent" Padding="14,9" Margin="0" Visibility="Visible">
                    <DockPanel LastChildFill="True" Margin="0">
                        <TextBlock x:Name="InlineThinkingStatusTextElement" Text="0 pending" Foreground="{DynamicResource FantasyCopperBrush}" FontSize="11" FontWeight="SemiBold" DockPanel.Dock="Right" VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock Text="运行证据 / Event stream" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" FontWeight="Bold" />
                            <TextBlock x:Name="InlineCompactStatusTextElement" Text="当前会话暂无独立产物 · 运行证据仍保留在 Runtime Delta" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="11" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Visibility="Collapsed">
                            <TextBlock x:Name="InlineWorkedStatusTextElement" Text="已工作 --" />
                            <Button x:Name="InlineOpenWebPreviewButtonElement" Content="打开" />
                            <TextBlock x:Name="InlineWebPreviewStatusTextElement" Text="网站" />
                            <Button x:Name="InlineUndoChangeButtonElement" Content="撤销" />
                            <Button x:Name="InlineReviewChangesButtonElement" Content="查看" />
                            <TextBlock x:Name="InlineChangesTitleTextElement" Text="已编辑文件" />
                            <TextBlock x:Name="InlineChangesMetaTextElement" Text="+0 -0" />
                            <ListBox x:Name="InlineGitChangesListElement" ItemTemplate="{StaticResource GitChangeTemplate}" SelectedValuePath="Path" />
                            <TextBox x:Name="InlineChangedFileDiffBoxElement" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <GridSplitter x:Name="ChatInputSplitterElement" Grid.Row="4" Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{StaticResource WorkspaceSplitter}" ResizeDirection="Rows" />
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="10*" MinWidth="680" MaxWidth="960" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                <Border x:Name="ChatComposerPanelElement" Grid.Column="1" HorizontalAlignment="Stretch" BorderBrush="{DynamicResource FantasyLineBrush}" BorderThickness="0" Padding="0,12,0,14" Margin="0" Background="Transparent" ClipToBounds="False">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="87" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="42" />
                        </Grid.RowDefinitions>
                        <ItemsControl x:Name="ComposerAttachmentsListElement" Grid.Row="0" ItemTemplate="{StaticResource ComposerAttachmentTemplate}" Margin="0,0,0,8" Visibility="Collapsed">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <Border Grid.Row="1"
                                Height="87"
                                Background="{DynamicResource AtelierComposerPaperBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AtelierComposerLineBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource FantasyPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                            <TextBox x:Name="PromptBoxElement" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" HorizontalContentAlignment="Stretch" Padding="10" FontSize="13" Height="85" MinHeight="85" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" ToolTipService.IsEnabled="False" />
                            <TextBlock x:Name="PromptPlaceholderTextElement"
                                       Text="发送给 Runtime 的文本，例如：打开管理模块、让 3D 模型播报当前阶段、批准 Android 命令队列。"
                                       Foreground="{DynamicResource FantasyMutedBrush}"
                                       FontSize="12.5"
                                       Margin="10,8,10,0"
                                       VerticalAlignment="Top"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text.Length, ElementName=PromptBoxElement}" Value="0" />
                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=PromptBoxElement}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="ComposerStatusPanelElement" Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,3,8,0" Visibility="Collapsed">
                            <TextBlock x:Name="AttachmentStatusTextElement" Text="" Style="{StaticResource MutedText}" VerticalAlignment="Center" Visibility="Collapsed" />
                            <Button x:Name="ClearPlanButtonElement" Content="× 计划" Height="24" MinHeight="24" Padding="8,0" Margin="6,0,0,0" Style="{StaticResource TinyButton}" Visibility="Collapsed" />
                            <Button x:Name="ClearGoalButtonElement" Content="× 目标" Height="24" MinHeight="24" Padding="8,0" Margin="6,0,0,0" Style="{StaticResource TinyButton}" Visibility="Collapsed" />
                        </StackPanel>
                        <Grid Grid.Row="3" Margin="8,6,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <DockPanel Grid.Column="0" LastChildFill="False" ClipToBounds="True">
                            <Button x:Name="CollaborationModeButtonElement" Content="模型协作" Height="28" MinHeight="28" Padding="2,0" Style="{StaticResource ComposerMenuButton}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource FantasyFaintTextBrush}" DockPanel.Dock="Left" Margin="0,0,14,0" ToolTip="开启模型协作对话" />
                            <Button x:Name="WebSearchModeButtonElement" Content="联网检索" Height="28" MinHeight="28" Padding="2,0" Style="{StaticResource ComposerMenuButton}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource FantasyFaintTextBrush}" DockPanel.Dock="Left" Margin="0,0,14,0" ToolTip="开启联网检索" />
                            <StackPanel x:Name="CollaborationComposerPanelElement"
                                        Orientation="Horizontal"
                                        DockPanel.Dock="Left"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="CollaborationComposerHintTextElement"
                                           Text="@ClaudeCode / @Codex / @all 指定协作端"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" />
                                <ComboBox x:Name="CollaborationComposerFromBoxElement" Width="86" Height="28" MinHeight="28" IsEditable="True" Text="human_desktop" Visibility="Collapsed">
                                    <ComboBoxItem Content="我" Tag="user" IsSelected="True" />
                                    <ComboBoxItem Content="Codex" Tag="codex" />
                                    <ComboBoxItem Content="Claude Code" Tag="claude_code" />
                                </ComboBox>
                                <ComboBox x:Name="CollaborationComposerToBoxElement" Width="122" Height="28" MinHeight="28" IsEditable="True" Text="all" Visibility="Collapsed">
                                    <ComboBoxItem Content="Claude Code" Tag="claude_code" IsSelected="True" />
                                    <ComboBoxItem Content="Codex" Tag="codex" />
                                    <ComboBoxItem Content="全部" Tag="all" />
                                </ComboBox>
                                <ComboBox x:Name="CollaborationComposerRoleBoxElement" Width="92" Height="28" MinHeight="28" IsEditable="True" Text="question" Visibility="Collapsed">
                                    <ComboBoxItem Content="问题" Tag="question" IsSelected="True" />
                                    <ComboBoxItem Content="回答" Tag="answer" />
                                    <ComboBoxItem Content="评审" Tag="review_request" />
                                    <ComboBoxItem Content="结果" Tag="review_result" />
                                    <ComboBoxItem Content="备注" Tag="note" />
                                </ComboBox>
                            </StackPanel>
                            <Button x:Name="AttachButtonElement" Content="+" Width="28" Height="28" Padding="0" MinHeight="28" Style="{StaticResource ComposerMenuButton}" Foreground="{DynamicResource FantasyFaintTextBrush}" DockPanel.Dock="Left" AutomationProperties.Name="添加附件" ToolTip="添加附件" />
                            <Button x:Name="AgentMentionButtonElement" Content="@" Width="28" Height="28" Padding="0" MinHeight="28" Margin="6,0,0,0" Style="{StaticResource ComposerMenuButton}" Foreground="{DynamicResource FantasyFaintTextBrush}" DockPanel.Dock="Left" AutomationProperties.Name="提及 Agent" ToolTip="@ Agent" />
                            <Button x:Name="PermissionButtonElement" Style="{StaticResource ComposerMenuButton}" DockPanel.Dock="Left" Margin="8,0,0,0" Height="28" MinHeight="28" Padding="4,0" Foreground="{DynamicResource FantasyWarningBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="PermissionTextElement" Text="完全访问" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="SaveNoteButtonElement" Content="存为记录" Width="88" Height="28" MinHeight="28" Padding="8,0" DockPanel.Dock="Left" Margin="8,0,0,0" Visibility="Collapsed" />
                            <ComboBox x:Name="QuickCommandBoxElement" Width="112" Height="28" MinHeight="28" DockPanel.Dock="Left" Margin="5,0,0,0" Padding="0" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource FantasyFaintTextBrush}" ItemTemplate="{StaticResource QuickCommandComboTemplate}" SelectedValuePath="Id" IsTextSearchEnabled="True" TextSearch.TextPath="Title" ToolTip="快速指令" />
                            <Button x:Name="ManageQuickCommandsButtonElement" Content="管理指令" Width="76" Height="28" MinHeight="28" Padding="8,0" DockPanel.Dock="Left" Margin="8,0,0,0" Visibility="Collapsed" />
                            </DockPanel>
                            <!-- 状态文案占用中间弹性列：显隐和长度变化都不移动输入框、左侧工具或发送按钮。 -->
                            <TextBlock x:Name="SendStatusTextElement"
                                       Grid.Column="1"
                                       Height="16"
                                       Text=""
                                       Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Visibility="Collapsed"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="120"
                                       Margin="12,0,8,0"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="ModelButtonElement" Style="{StaticResource ComposerMenuButton}" Height="28" MinHeight="28" Padding="5,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ModelTextElement" Text="自动（主模型）" Foreground="{DynamicResource FantasyTextBrush}" VerticalAlignment="Center" MaxWidth="90" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ReasoningButtonElement" Style="{StaticResource ComposerMenuButton}" Height="28" MinHeight="28" Padding="5,0" Margin="6,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ReasoningTextElement" Text="自动推理" Foreground="{DynamicResource FantasyFaintTextBrush}" VerticalAlignment="Center" MaxWidth="68" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="⌄" Style="{StaticResource ComposerChevronText}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="SendButtonElement" Content="发送" Width="56" Height="28" Style="{StaticResource AtelierComposerSendButton}" ToolTip="发送" />
                            </StackPanel>
                        </Grid>
                        <!-- @提及预览改为悬浮气泡：不再占用底部状态行（原先在右下角常被裁切）。 -->
                        <Popup x:Name="AgentMentionPopupElement" PlacementTarget="{Binding ElementName=PromptBoxElement}" Placement="Top" HorizontalOffset="8" VerticalOffset="-4" AllowsTransparency="True" StaysOpen="True">
                            <Border Background="{DynamicResource FantasySurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="10,5">
                                <TextBlock x:Name="AgentMentionStatusTextElement" Text="" Style="{StaticResource MutedText}" />
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
                </Grid>
                </Grid>
            </Grid>
        </Border>

        
</UserControl>
