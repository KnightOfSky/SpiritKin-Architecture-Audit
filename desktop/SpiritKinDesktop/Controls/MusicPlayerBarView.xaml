<UserControl x:Class="SpiritKinDesktop.Controls.MusicPlayerBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="58"
             Background="{DynamicResource FantasySurfaceBrush}"
             Foreground="{DynamicResource FantasyTextBrush}"
             FontFamily="{StaticResource UiFontFamily}">
    <UserControl.Resources>
        <Style x:Key="MediaIconButton" TargetType="Button" BasedOn="{StaticResource TinyButton}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="{DynamicResource FantasyLineBrush}" BorderThickness="0,1,0,0" Padding="12,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MediaIconButton}" Content="&#xE892;" Click="PreviousButton_Click" ToolTip="上一首" AutomationProperties.Name="上一首" />
                <Button x:Name="PlayPauseButton" Style="{StaticResource MediaIconButton}" Content="&#xE768;" Click="PlayPauseButton_Click" ToolTip="播放" AutomationProperties.Name="播放或暂停" />
                <Button Style="{StaticResource MediaIconButton}" Content="&#xE893;" Click="NextButton_Click" ToolTip="下一首" AutomationProperties.Name="下一首" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Center">
                <TextBlock x:Name="TrackTitleText" Text="未选择音乐" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="PlaybackStatusText" Text="" FontSize="10" Foreground="{DynamicResource FantasyMutedBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Grid Grid.Column="2" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="PositionText" Text="00:00" Width="42" FontFamily="{StaticResource MonoFontFamily}" FontSize="10" VerticalAlignment="Center" />
                <Slider x:Name="PositionSlider" Grid.Column="1" Minimum="0" Maximum="1" ValueChanged="PositionSlider_ValueChanged" Margin="6,0" AutomationProperties.Name="播放进度" />
                <TextBlock x:Name="DurationText" Grid.Column="2" Text="00:00" Width="42" FontFamily="{StaticResource MonoFontFamily}" FontSize="10" TextAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Column="3" Margin="12,0,8,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE767;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource FantasyMutedBrush}" />
                <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0" Maximum="1" Value="0.8" ValueChanged="VolumeSlider_ValueChanged" AutomationProperties.Name="音乐音量" />
            </Grid>

            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="QueueButton" Style="{StaticResource MediaIconButton}" Content="&#xE8FD;" Click="QueueButton_Click" ToolTip="播放队列" AutomationProperties.Name="播放队列" />
                <Button Style="{StaticResource MediaIconButton}" Content="&#xE711;" Click="CloseButton_Click" ToolTip="关闭播放器" AutomationProperties.Name="关闭播放器" />
            </StackPanel>

            <Popup x:Name="QueuePopup"
                   PlacementTarget="{Binding ElementName=QueueButton}"
                   Placement="Top"
                   HorizontalOffset="-320"
                   VerticalOffset="-8"
                   AllowsTransparency="True"
                   StaysOpen="False">
                <Border Width="380"
                        Height="390"
                        Background="{DynamicResource FantasySurfaceBrush}"
                        BorderBrush="{DynamicResource FantasyBorderBrush}"
                        BorderThickness="1"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="播放队列" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource MediaIconButton}" Content="&#xE8E5;" Click="AddFilesButton_Click" ToolTip="添加音乐文件" AutomationProperties.Name="添加音乐文件" />
                                <Button Style="{StaticResource MediaIconButton}" Content="&#xE8B7;" Click="AddFolderButton_Click" ToolTip="添加音乐目录" AutomationProperties.Name="添加音乐目录" />
                            </StackPanel>
                        </Grid>
                        <ListBox x:Name="QueueList"
                                 Grid.Row="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionChanged="QueueList_SelectionChanged"
                                 DisplayMemberPath="Title"
                                 AutomationProperties.Name="音乐播放队列" />
                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34" />
                                <RowDefinition Height="34" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="循环" VerticalAlignment="Center" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="11" />
                            <ComboBox x:Name="LoopModeBox" Grid.Column="1" SelectedIndex="0" SelectionChanged="LoopModeBox_SelectionChanged">
                                <ComboBoxItem Content="不循环" Tag="Off" />
                                <ComboBoxItem Content="列表循环" Tag="All" />
                                <ComboBoxItem Content="单曲循环" Tag="One" />
                            </ComboBox>
                            <TextBlock Grid.Row="1" Text="语音占用" VerticalAlignment="Center" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="11" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <ComboBox x:Name="AudioFocusBox" Width="116" SelectedIndex="0" SelectionChanged="AudioFocusBox_SelectionChanged">
                                    <ComboBoxItem Content="降低音量" Tag="Duck" />
                                    <ComboBoxItem Content="暂停" Tag="Pause" />
                                    <ComboBoxItem Content="忽略" Tag="Ignore" />
                                </ComboBox>
                                <CheckBox x:Name="ResumeAfterPauseCheckBox" Content="结束后恢复" Margin="12,0,0,0" VerticalAlignment="Center" Checked="ResumeAfterPauseCheckBox_Changed" Unchecked="ResumeAfterPauseCheckBox_Changed" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
