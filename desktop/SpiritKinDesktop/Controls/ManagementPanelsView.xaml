<UserControl x:Class="SpiritKinDesktop.Controls.ManagementPanelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SpiritKinDesktop.Controls"
             xmlns:local="clr-namespace:SpiritKinDesktop"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <UserControl.Resources>
        <Style x:Key="CollaborationCompactTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="Background" Value="{DynamicResource FantasySurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource FantasyTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="CollaborationCompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="{DynamicResource FantasySurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource FantasyTextBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid>
                    <Grid x:Name="TasksPanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="128" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="任务管理" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ListBox x:Name="TaskSubNavList" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource ModuleNavItem}">
                                <ListBoxItem Content="当前会话" Tag="sessions" IsSelected="True" />
                                <ListBoxItem Content="项目" Tag="projects" />
                                <ListBoxItem Content="任务" Tag="tasks" />
                            </ListBox>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{DynamicResource LineBrush}" Width="1" Margin="0,0,0,0" />
                        <Grid Grid.Column="2">
                            <StackPanel x:Name="SessionManagementPage">
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="会话管理" Style="{StaticResource ManagementPageTitle}" />
                                        <TextBlock x:Name="SessionManagementStatusText" Text="管理所有 Chats 与项目会话；左侧选择会话，右侧编辑标题和状态。" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <WrapPanel HorizontalAlignment="Right">
                                        <Button x:Name="CreateSessionFromPanelButton" Content="新增" MinWidth="64" />
                                        <Button x:Name="SaveSessionButton" Content="保存" MinWidth="64" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                                        <Button x:Name="ArchiveSessionButton" Content="归档" MinWidth="82" Margin="8,0,0,0" />
                                        <Button x:Name="DeleteSessionButton" Content="删除" MinWidth="64" Margin="8,0,0,0" Style="{StaticResource DangerButton}" />
                                    </WrapPanel>
                                </DockPanel>
                                <Border Style="{StaticResource ListPanelBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="260" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ListBox x:Name="ManagedSessionsList"
                                                 Grid.Column="0"
                                                 ItemTemplate="{StaticResource ManagedSessionTemplate}"
                                                 SelectedValuePath="SessionId"
                                                 SelectionChanged="ManagedSessionsList_SelectionChanged"
                                                 MaxHeight="430"
                                                 VerticalAlignment="Top"
                                                 BorderBrush="{DynamicResource FantasyLineBrush}"
                                                 Background="{DynamicResource PanelAltBrush}"
                                                 ScrollViewer.CanContentScroll="False"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 VirtualizingPanel.IsVirtualizing="False">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel IsItemsHost="True" VerticalAlignment="Top" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                        </ListBox>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="会话标题" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="SessionTitleEditBox" Margin="0,0,0,8" />
                                            <TextBlock Text="会话状态" Style="{StaticResource FieldLabel}" />
                                            <ComboBox x:Name="SessionStatusBox" Margin="0,0,0,8">
                                                <ComboBoxItem Content="活动" Tag="active" IsSelected="True" />
                                                <ComboBoxItem Content="归档" Tag="archived" />
                                            </ComboBox>
                                            <TextBlock x:Name="SelectedSessionDetailText" Text="--" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,12" />
                                            <UniformGrid Columns="3">
                                                <Button x:Name="OpenManagedSessionButton" Content="打开会话" Margin="0,0,4,0" />
                                                <Button x:Name="MoveSessionToChatsButton" Content="移到 Chats" Margin="4,0,4,0" />
                                                <Button x:Name="PinManagedSessionButton" Content="置顶/取消" Margin="4,0,0,0" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="ProjectManagementPage" Visibility="Collapsed">
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="项目" Style="{StaticResource ManagementPageTitle}" />
                                        <TextBlock x:Name="ProjectManagementStatusText" Text="选择左侧项目后编辑状态和说明" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <WrapPanel HorizontalAlignment="Right">
                                        <Button x:Name="CreateProjectFromPanelButton" Content="新增" Width="64" />
                                        <Button x:Name="SaveProjectButton" Content="保存" Width="64" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                                        <Button x:Name="ArchiveProjectButton" Content="归档项目" Width="82" Margin="8,0,0,0" />
                                        <Button x:Name="DeleteProjectButton" Content="删除" Width="64" Margin="8,0,0,0" Style="{StaticResource DangerButton}" />
                                    </WrapPanel>
                                </DockPanel>
                                <Border Style="{StaticResource ListPanelBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ListBox x:Name="RightProjectsList"
                                                 Grid.Column="0"
                                                 ItemTemplate="{StaticResource ProjectManagementTemplate}"
                                                 SelectedValuePath="Id"
                                                 SelectionChanged="RightProjectsList_SelectionChanged"
                                                 MinHeight="160"
                                                 MaxHeight="430"
                                                 VerticalAlignment="Top"
                                                 BorderBrush="{DynamicResource FantasyLineBrush}"
                                                 Background="{DynamicResource PanelAltBrush}"
                                                 ScrollViewer.CanContentScroll="False"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 VirtualizingPanel.IsVirtualizing="False">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel IsItemsHost="True" VerticalAlignment="Top" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                        </ListBox>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="项目标题" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="ProjectTitleEditBox" Margin="0,0,0,8" />
                                            <TextBlock Text="项目状态" Style="{StaticResource FieldLabel}" />
                                            <ComboBox x:Name="ProjectStatusBox" Margin="0,0,0,8">
                                                <ComboBoxItem Content="活动" Tag="active" IsSelected="True" />
                                                <ComboBoxItem Content="归档" Tag="archived" />
                                                <ComboBoxItem Content="暂停" Tag="paused" />
                                                <ComboBoxItem Content="完成" Tag="complete" />
                                                <ComboBoxItem Content="阻塞" Tag="blocked" />
                                            </ComboBox>
                                            <TextBlock Text="项目说明" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="ProjectDetailEditBox" AcceptsReturn="True" TextWrapping="Wrap" Height="86" Margin="0,0,0,12" />
                                            <TextBlock Text="工作区路径" Style="{StaticResource FieldLabel}" />
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="72" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="ProjectWorkspacePathBox" Grid.Column="0" IsReadOnly="True" ToolTip="项目工作区在新增项目时确定；如需更换，请新建项目。" />
                                                <Button x:Name="OpenProjectWorkspaceButton" Grid.Column="2" Content="打开" />
                                            </Grid>
                                            <TextBlock Text="运行环境文件" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="ProjectEnvFileBox" Margin="0,0,0,8" ToolTip="例如 .env、.env.local 或 config/dev.env，路径相对项目工作区。" />
                                            <TextBlock Text="依赖文件" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="ProjectDependencyFileBox" Margin="0,0,0,8" ToolTip="例如 requirements.txt、pyproject.toml、package.json、pnpm-lock.yaml。" />
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="包管理器" Style="{StaticResource FieldLabel}" />
                                                    <ComboBox x:Name="ProjectPackageManagerBox" IsEditable="True">
                                                        <ComboBoxItem Content="auto" IsSelected="True" />
                                                        <ComboBoxItem Content="uv" />
                                                        <ComboBoxItem Content="pip" />
                                                        <ComboBoxItem Content="poetry" />
                                                        <ComboBoxItem Content="npm" />
                                                        <ComboBoxItem Content="pnpm" />
                                                        <ComboBoxItem Content="yarn" />
                                                        <ComboBoxItem Content="dotnet" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="启动命令" Style="{StaticResource FieldLabel}" />
                                                    <TextBox x:Name="ProjectStartCommandBox" ToolTip="项目默认启动/调试命令，只记录，不自动执行。" />
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel Margin="0,0,0,8">
                                                <Button x:Name="DetectProjectRuntimeButton" Content="探测运行配置" MinWidth="116" />
                                                <Button x:Name="RunProjectStartCommandButton" Content="运行启动命令" MinWidth="104" Margin="8,0,0,0" />
                                            </WrapPanel>
                                            <TextBlock x:Name="ProjectRuntimeSummaryText" Text="项目运行配置会用于终端、外部助手和后续执行隔离。" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                            <DockPanel Margin="0,0,0,8">
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="项目会话" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="ProjectSessionStatusText" Text="选择项目后可管理项目内会话" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <WrapPanel HorizontalAlignment="Right">
                                                    <Button x:Name="NewProjectSessionButton" Content="新建会话" MinWidth="78" />
                                                    <Button x:Name="RenameProjectSessionButton" Content="重命名" MinWidth="70" Margin="8,0,0,0" />
                                                    <Button x:Name="ArchiveProjectSessionButton" Content="归档" MinWidth="70" Margin="8,0,0,0" />
                                                    <Button x:Name="DeleteProjectSessionButton" Content="删除" MinWidth="64" Margin="8,0,0,0" Style="{StaticResource DangerButton}" />
                                                </WrapPanel>
                                            </DockPanel>
                                            <ListBox x:Name="ProjectSessionsList" ItemTemplate="{StaticResource ProjectTemplate}" SelectedValuePath="SessionId" SelectionChanged="ProjectSessionsList_SelectionChanged" Height="190" BorderBrush="{DynamicResource FantasyLineBrush}" Background="{DynamicResource PanelAltBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="TaskManagementPage" Visibility="Collapsed">
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="任务" Style="{StaticResource ManagementPageTitle}" />
                                        <TextBlock Text="选中一个任务后编辑标题、状态和说明" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <WrapPanel HorizontalAlignment="Right">
                                        <Button x:Name="CreateTaskFromPanelButton" Content="新增" Width="64" />
                                        <Button x:Name="SaveTaskButton" Content="保存" Width="64" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                                        <Button x:Name="DeleteTaskButton" Content="删除" Width="64" Margin="8,0,0,0" Style="{StaticResource DangerButton}" />
                                    </WrapPanel>
                                </DockPanel>
                                <Border Style="{StaticResource ListPanelBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ListBox x:Name="RightTasksList" ItemTemplate="{StaticResource TaskTemplate}" SelectedValuePath="Id" SelectionChanged="RightTasksList_SelectionChanged" Height="260" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="任务标题" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="TaskTitleEditBox" Margin="0,0,0,8" />
                                            <TextBlock Text="任务状态" Style="{StaticResource FieldLabel}" />
                                            <ComboBox x:Name="TaskStatusBox" Margin="0,0,0,8">
                                                <ComboBoxItem Content="待处理" Tag="pending" IsSelected="True" />
                                                <ComboBoxItem Content="进行中" Tag="running" />
                                                <ComboBoxItem Content="完成" Tag="complete" />
                                                <ComboBoxItem Content="阻塞" Tag="blocked" />
                                            </ComboBox>
                                            <TextBlock Text="任务说明" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="TaskDetailEditBox" AcceptsReturn="True" TextWrapping="Wrap" Height="120" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <ScrollViewer x:Name="TracePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Visible">
                        <StackPanel>
                            <Expander Header="当前执行" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <TextBlock x:Name="ExecutionText" Text="--" Foreground="{DynamicResource FantasyMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </Expander>
                            <Expander Header="智能体路由" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <TextBlock x:Name="RouteText" Text="--" Foreground="{DynamicResource FantasyMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </Expander>
                            <Expander Header="最近事件" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <ListBox x:Name="EventsList" ItemTemplate="{StaticResource EventTemplate}" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" MaxHeight="280" Margin="0,8,0,0" />
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="SyncPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Visible">
                        <StackPanel>
                            <Expander Header="同步状态与动作" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock x:Name="SyncText" Text="--" Foreground="{DynamicResource FantasyMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                    <WrapPanel>
                                        <Button x:Name="RefreshSyncButton" Content="刷新同步" Width="86" />
                                        <Button x:Name="ClearSyncEventsButton" Content="清理事件" Width="86" Margin="8,0,0,0" />
                                        <Button x:Name="ClearPendingButton" Content="清除待确认" Width="94" Margin="8,0,0,0" />
                                        <Button x:Name="CompactSessionsButton" Content="压缩会话" Width="86" Margin="8,0,0,0" />
                                    </WrapPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Header="客户端 / 事件来源" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <ListBox x:Name="SyncClientsList" ItemTemplate="{StaticResource EventTemplate}" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" MaxHeight="260" Margin="0,8,0,0" />
                            </Expander>
                            <Expander Header="最近同步事件" Style="{StaticResource ManagementExpander}" IsExpanded="False">
                                <TextBox x:Name="SyncLastEventBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="140" Margin="0,8,0,0" />
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="ServicesPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Visible">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button x:Name="RefreshServicesButton" Content="刷新服务" Width="86" />
                                <TextBlock x:Name="ServiceActionText" Text="--" Style="{StaticResource MutedText}" Margin="10,8,0,0" />
                            </WrapPanel>
                            <Expander Header="服务端口管理" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <ListBox x:Name="ServicesList" ItemTemplate="{StaticResource ServiceTemplate}" SelectedValuePath="ServiceId" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" MaxHeight="360" Margin="0,8,0,0" />
                            </Expander>
                            <Expander Header="端口注册表" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <StackPanel>
                                    <WrapPanel Margin="0,8,0,8">
                                        <TextBlock Text="选中端口" Style="{StaticResource MutedText}" Margin="0,6,6,0" />
                                        <TextBox x:Name="ServicePortValueBox" Width="88" Height="28" VerticalContentAlignment="Center" />
                                        <Button x:Name="SaveServicePortButton" Content="保存端口" Width="82" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" />
                                        <Button x:Name="ResetServicePortButton" Content="重置" Width="58" Margin="8,0,0,0" />
                                        <Button x:Name="RepairServicePortsButton" Content="修复重复" Width="86" Margin="8,0,0,0" />
                                        <Button x:Name="RestartPortServicesButton" Content="重启相关服务" Width="104" Margin="8,0,0,0" />
                                        <Button x:Name="ApplyServicePortClientUrlsButton" Content="应用到桌面连接" Width="116" Margin="8,0,0,0" />
                                        <Button x:Name="CopyServicePortMigrationButton" Content="复制迁移提示" Width="104" Margin="8,0,0,0" />
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button x:Name="SaveProjectPortProfileButton" Content="保存项目端口配置" Width="136" />
                                        <Button x:Name="ApplyProjectPortProfileButton" Content="应用项目配置" Width="116" Margin="8,0,0,0" />
                                        <Button x:Name="DeleteProjectPortProfileButton" Content="删除项目配置" Width="116" Margin="8,0,0,0" />
                                    </WrapPanel>
                                    <TextBlock x:Name="ServicePortConfigText" Text="--" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="ServicePortRestartText" Text="端口变化后会在这里显示重启与迁移提示。" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    <ListBox x:Name="ServicePortsList" ItemTemplate="{StaticResource EventTemplate}" SelectedValuePath="Id" SelectionChanged="ServicePortsList_SelectionChanged" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" MaxHeight="260" Margin="0,8,0,0" />
                                </StackPanel>
                            </Expander>
                            <Expander Header="最近服务动作" Style="{StaticResource ManagementExpander}" IsExpanded="False">
                                <ListBox x:Name="ServiceActionsList" ItemTemplate="{StaticResource EventTemplate}" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" Height="150" Margin="0,8,0,0" />
                            </Expander>
                            <Expander Header="服务说明" Style="{StaticResource ManagementExpander}" IsExpanded="False">
                                <TextBlock Text="命令网关重启会先返回调度结果，再由后台 helper 重启自身；其它服务可直接启动、停止或重启，日志会写入 state/logs。" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="LogsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Visible">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button x:Name="RefreshLogsButton" Content="刷新日志" Width="86" />
                                <Button x:Name="OpenSelectedLogButton" Content="打开日志" Width="86" Margin="8,0,0,0" />
                                <Button x:Name="OpenSelectedLogFolderButton" Content="打开目录" Width="86" Margin="8,0,0,0" />
                                <Button x:Name="ArchiveSelectedLogButton" Content="归档日志" Width="86" Margin="8,0,0,0" />
                                <Button x:Name="DeleteSelectedLogButton" Content="删除日志" Width="86" Margin="8,0,0,0" Style="{StaticResource DangerButton}" />
                            </WrapPanel>
                            <Expander Header="统一动作日志" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <StackPanel>
                                    <TextBlock x:Name="UnifiedActionLogSummaryText" Text="--" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    <ListBox x:Name="UnifiedActionLogList" ItemTemplate="{StaticResource EventTemplate}" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" MaxHeight="220" Margin="0,8,0,0" />
                                </StackPanel>
                            </Expander>
                            <Expander Header="项目错误日志" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <ListBox x:Name="LogsList" ItemTemplate="{StaticResource LogTemplate}" SelectedValuePath="LogId" SelectionChanged="LogsList_SelectionChanged" Height="170" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" Margin="0,8,0,0" />
                            </Expander>
                            <Expander Header="日志尾部" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <TextBox x:Name="LogTailBox" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Height="260" Margin="0,8,0,0" />
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="DailyPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Visible">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button x:Name="RefreshDailyButton" Content="刷新日报" Width="86" />
                                <Button x:Name="OpenDailyItemButton" Content="定位事项" Width="86" Margin="8,0,0,0" />
                                <Button x:Name="StartDailyTaskButton" Content="开始任务" Width="86" Margin="8,0,0,0" />
                                <Button x:Name="CompleteDailyTaskButton" Content="完成任务" Width="86" Margin="8,0,0,0" />
                                <Button x:Name="BlockDailyTaskButton" Content="阻塞任务" Width="86" Margin="8,0,0,0" />
                                <TextBlock x:Name="DailyActionText" Text="--" Style="{StaticResource MutedText}" Margin="10,8,0,0" />
                            </WrapPanel>
                            <Expander Header="每日任务与学习" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <TextBlock x:Name="DailySummaryText" Text="--" Foreground="{DynamicResource FantasyMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </Expander>
                            <Expander Header="今日项目事项" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <ListBox x:Name="DailyItemsList" ItemTemplate="{StaticResource EventTemplate}" SelectedValuePath="Id" SelectionChanged="DailyItemsList_SelectionChanged" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" MaxHeight="360" Margin="0,8,0,0" />
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="DiagnosticsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Visible">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button x:Name="RefreshDiagnosticsButton" Content="刷新诊断" Width="96" />
                                <Button x:Name="AutoRepairDiagnosticsButton" Content="一键自修复" Width="96" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                                <Button x:Name="CopyDiagnosticCommandButton" Content="复制命令" Width="86" Margin="8,0,0,0" />
                                <Button x:Name="RunDiagnosticCommandButton" Content="终端运行" Width="86" Margin="8,0,0,0" />
                                <TextBlock x:Name="DiagnosticActionText" Text="--" Style="{StaticResource MutedText}" Margin="10,8,0,0" />
                            </WrapPanel>
                            <Expander Header="服务与依赖" Style="{StaticResource ManagementExpander}" IsExpanded="True">
