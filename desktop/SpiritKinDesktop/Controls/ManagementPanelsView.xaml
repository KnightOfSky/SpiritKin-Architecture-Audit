                                        <TextBox x:Name="CollaborationDecisionBox" AcceptsReturn="True" TextWrapping="Wrap" Height="62" Background="{DynamicResource FantasySurfaceBrush}" Foreground="{DynamicResource FantasyTextBrush}" />
                                        <TextBlock Text="原因" Style="{StaticResource FieldLabel}" Margin="0,8,0,0" />
                                        <TextBox x:Name="CollaborationDecisionRationaleBox" AcceptsReturn="True" TextWrapping="Wrap" Height="62" Background="{DynamicResource FantasySurfaceBrush}" Foreground="{DynamicResource FantasyTextBrush}" />
