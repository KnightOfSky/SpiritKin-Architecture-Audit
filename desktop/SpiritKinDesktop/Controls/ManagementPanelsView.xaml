                                                        </Border>
                                                        <Border BorderBrush="{DynamicResource FantasyInfoBrush}" BorderThickness="1" Background="{DynamicResource FantasyHoverSoftBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,4">
                                                            <TextBlock Text="技能" Foreground="{DynamicResource FantasyPrimaryStrongBrush}" FontSize="10" FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border BorderBrush="{DynamicResource FantasyWarningBrush}" BorderThickness="1" Background="{DynamicResource FantasyWarningWashBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,4">
                                                            <TextBlock Text="审核" Foreground="{DynamicResource FantasyWarningTextBrush}" FontSize="10" FontWeight="SemiBold" />
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Top">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,10,0">
