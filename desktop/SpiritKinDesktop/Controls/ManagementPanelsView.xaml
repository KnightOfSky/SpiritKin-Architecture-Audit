                                                    <ComboBoxItem Content="Claude Code" Tag="claude_code" IsSelected="True" />
                                                    <ComboBoxItem Content="Codex" Tag="codex" />
                                                    <ComboBoxItem Content="外部评审 Agent" Tag="external_reviewer" />
                                                    <ComboBoxItem Content="全部" Tag="all" />
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Margin="8,0,0,0">
