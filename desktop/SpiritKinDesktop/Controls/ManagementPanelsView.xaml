                                        <TextBox x:Name="CollaborationMessageContextPackBox" Style="{StaticResource CollaborationCompactTextBox}" ToolTip="留空时使用下方“最近上下文路径”" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button x:Name="SendCollaborationMessageInlineButton" Content="发送消息" Width="88" Height="32" Style="{StaticResource PrimaryButton}" />
