                                    </StackPanel>
                                </Grid>
                            </Expander>
                            <Expander Header="协作任务记录" Style="{StaticResource ManagementExpander}" IsExpanded="True">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" MinWidth="420" />
