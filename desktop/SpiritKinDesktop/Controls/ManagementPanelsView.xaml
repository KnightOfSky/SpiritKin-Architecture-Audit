                                                        <Button x:Name="EditSelectedWorkflowNodeButton" Content="编辑节点" Height="28" MinHeight="28" Padding="9,0" Style="{StaticResource TinyButton}" Margin="0,0,8,0" ToolTip="展开左侧工作流设计器并编辑当前节点" />
                                                        <Button x:Name="AutoLayoutWorkflowGraphButton" Content="自动排布" Height="28" MinHeight="28" Padding="9,0" Style="{StaticResource TinyButton}" Margin="0,0,8,0" ToolTip="按依赖层级重新排布当前工作流节点" />
                                                        <Button x:Name="WorkflowZoomOutButton" Content="-" Width="30" Height="28" MinHeight="28" Padding="0" Style="{StaticResource TinyButton}" Margin="0,0,6,0" AutomationProperties.Name="缩小画布" ToolTip="缩小画布" />
                                                        <TextBlock x:Name="WorkflowZoomText" Text="100%" Width="46" Style="{StaticResource MutedText}" TextAlignment="Center" VerticalAlignment="Center" />
