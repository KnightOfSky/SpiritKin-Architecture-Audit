                                                        <Border BorderBrush="{DynamicResource FantasyPrimaryBrush}" BorderThickness="1" Background="{DynamicResource PanelAltBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,4">
                                                            <TextBlock Text="智能体" Foreground="{DynamicResource FantasyPrimaryBrush}" FontSize="10" FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border BorderBrush="{DynamicResource FantasySuccessBrush}" BorderThickness="1" Background="{DynamicResource FantasySuccessSoftWashBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,4">
