                                                        <Button x:Name="WorkflowZoomResetButton" Content="1:1" Width="42" Height="28" MinHeight="28" Padding="0" Style="{StaticResource TinyButton}" AutomationProperties.Name="重置缩放" ToolTip="重置缩放" />
