                                                            <ComboBoxItem Content="产物" Tag="artifact" />
                                                            <ComboBoxItem Content="知识" Tag="knowledge" />
                                                            <ComboBoxItem Content="信号" Tag="signal" />
                                                            <ComboBoxItem Content="审核" Tag="review" />
                                                            <ComboBoxItem Content="自动化" Tag="automation" />
                                                            <ComboBoxItem Content="控制" Tag="control" />
                                                            <ComboBoxItem Content="任意" Tag="*" />
