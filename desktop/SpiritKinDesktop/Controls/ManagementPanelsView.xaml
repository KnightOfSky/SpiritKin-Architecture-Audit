                                        </DockPanel>
                                        <TextBlock Text="共享范围 / 路径" Style="{StaticResource FieldLabel}" />
                                        <DockPanel Margin="0,0,0,8">
                                            <ComboBox x:Name="KnowledgeBaseScopeBox" Width="150" DockPanel.Dock="Right" Margin="8,0,0,0" Background="{DynamicResource FantasySurfaceBrush}" Foreground="{DynamicResource FantasyTextBrush}">
                                                <ComboBoxItem Content="单 Agent" Tag="agent" IsSelected="True" />
                                                <ComboBoxItem Content="领域共享" Tag="domain" />
                                                <ComboBoxItem Content="全局共享" Tag="global" />
                                            </ComboBox>
                                            <Button x:Name="BrowseKnowledgeBasePathButton" Content="路径" Width="52" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource TinyButton}" />
                                            <TextBox x:Name="KnowledgeBasePathBox" />
                                        </DockPanel>
                                        <CheckBox x:Name="KnowledgeBaseEnabledBox" Content="启用知识库" IsChecked="True" Margin="0,0,0,8" />
                                        <TextBlock x:Name="KnowledgeBaseIndexStatusText" Text="索引状态：未检查" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                        <TextBlock Text="备注" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="KnowledgeBaseNotesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="110" />
                                    </StackPanel>
                                </Grid>
                                <Expander Header="外部知识源 / Obsidian" Style="{StaticResource ManagementExpander}" IsExpanded="True" Margin="0,12,0,0">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <ListBox x:Name="KnowledgeSourcesList" ItemTemplate="{StaticResource EventTemplate}" SelectedValuePath="SourceId" Height="210" />
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button x:Name="NewKnowledgeSourceButton" Content="新增源" Grid.Row="0" Grid.Column="0" Style="{StaticResource TinyButton}" />
                                                <Button x:Name="SaveKnowledgeSourceButton" Content="保存源" Grid.Row="0" Grid.Column="2" Style="{StaticResource TinyButton}" />
                                                <Button x:Name="SyncKnowledgeSourceButton" Content="同步索引" Grid.Row="2" Grid.Column="0" Style="{StaticResource TinyButton}" />
                                                <Button x:Name="DeleteKnowledgeSourceButton" Content="删除源" Grid.Row="2" Grid.Column="2" Style="{StaticResource DangerTinyButton}" />
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="源 ID / 名称" Style="{StaticResource FieldLabel}" />
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBox x:Name="KnowledgeSourceLabelBox" Width="170" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                                <TextBox x:Name="KnowledgeSourceIdBox" />
                                            </DockPanel>
                                            <TextBlock Text="类型 / 目标知识库" Style="{StaticResource FieldLabel}" />
                                            <DockPanel Margin="0,0,0,8">
                                                <ComboBox x:Name="KnowledgeSourceTargetBox" Width="190" DockPanel.Dock="Right" Margin="8,0,0,0" DisplayMemberPath="Label" SelectedValuePath="KnowledgeBaseId" />
                                                <ComboBox x:Name="KnowledgeSourceKindBox" IsEditable="True" Background="{DynamicResource FantasySurfaceBrush}" Foreground="{DynamicResource FantasyTextBrush}">
                                                    <ComboBoxItem Content="Obsidian Vault" Tag="obsidian" />
                                                    <ComboBoxItem Content="本地文件夹" Tag="folder" IsSelected="True" />
                                                </ComboBox>
                                            </DockPanel>
                                            <TextBlock Text="外部路径" Style="{StaticResource FieldLabel}" />
                                            <DockPanel Margin="0,0,0,8">
                                                <Button x:Name="BrowseKnowledgeSourcePathButton" Content="路径" Width="52" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource TinyButton}" />
                                                <TextBox x:Name="KnowledgeSourcePathBox" />
                                            </DockPanel>
                                            <WrapPanel Margin="0,0,0,8">
                                                <CheckBox x:Name="KnowledgeSourceEnabledBox" Content="启用" IsChecked="True" />
                                                <CheckBox x:Name="KnowledgeSourceRecursiveBox" Content="递归" IsChecked="True" Margin="16,0,0,0" />
                                            </WrapPanel>
                                            <TextBlock Text="忽略规则 / 标签过滤" Style="{StaticResource FieldLabel}" />
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBox x:Name="KnowledgeSourceTagsBox" Width="170" DockPanel.Dock="Right" Margin="8,0,0,0" ToolTip="逗号或换行分隔标签；留空表示不过滤" />
                                                <TextBox x:Name="KnowledgeSourceIgnoreBox" ToolTip="逗号或换行分隔忽略规则" />
                                            </DockPanel>
                                            <TextBlock x:Name="KnowledgeSourceStatusText" Text="外部源状态：未选择" Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                            <TextBlock Text="备注" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="KnowledgeSourceNotesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="70" />
                                        </StackPanel>
                                    </Grid>
                                </Expander>
                            </StackPanel>

                            <StackPanel x:Name="RouteProfilesPage" Visibility="Collapsed">
                                <TextBlock Text="路由组合" Style="{StaticResource ManagementPageTitle}" />
                                <TextBlock Text="定义主模型、专家模型、评审链和降级链" Style="{StaticResource MutedText}" Margin="0,3,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <ListBox x:Name="RouteProfilesList" ItemTemplate="{StaticResource EventTemplate}" SelectedValuePath="ProfileId" SelectionChanged="RouteProfilesList_SelectionChanged" Height="240" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button x:Name="NewRouteProfileButton" Content="新增" Width="52" Style="{StaticResource TinyButton}" />
                                            <Button x:Name="ApplyRouteProfileButton" Content="应用" Width="52" Style="{StaticResource TinyButton}" Margin="6,0,0,0" />
                                            <Button x:Name="DeleteRouteProfileButton" Content="删除" Width="52" Style="{StaticResource DangerTinyButton}" Margin="6,0,0,0" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="组合 ID / 名称" Style="{StaticResource FieldLabel}" />
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBox x:Name="RouteProfileLabelBox" Width="130" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <TextBox x:Name="RouteProfileIdBox" />
                                        </DockPanel>
                                        <TextBlock Text="策略" Style="{StaticResource FieldLabel}" />
                                        <ComboBox x:Name="RouteStrategyBox" Background="{DynamicResource FantasySurfaceBrush}" Foreground="{DynamicResource FantasyTextBrush}" Margin="0,0,0,8">
                                            <ComboBoxItem Content="主模型 + 专家" Tag="primary_with_specialists" IsSelected="True" />
                                            <ComboBoxItem Content="多模型评审" Tag="committee_review" />
                                            <ComboBoxItem Content="降级链" Tag="fallback_chain" />
                                        </ComboBox>
                                        <CheckBox x:Name="RouteProfileEnabledBox" Content="启用组合" IsChecked="True" Margin="0,0,0,8" />
                                        <TextBlock Text="成员 JSON / 备注" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="RouteMembersJsonBox" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Height="96" Margin="0,0,0,8" />
                                        <TextBox x:Name="RouteProfileNotesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="52" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="RemoteTargetsPage" Visibility="Collapsed">
                                <TextBlock Text="远端目标与导出" Style="{StaticResource ManagementPageTitle}" />
                                <TextBlock Text="配置远端节点，并导出 Skill 包" Style="{StaticResource MutedText}" Margin="0,3,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <ListBox x:Name="RemoteTargetsList" ItemTemplate="{StaticResource EventTemplate}" SelectedValuePath="TargetId" SelectionChanged="RemoteTargetsList_SelectionChanged" Height="220" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button x:Name="NewRemoteTargetButton" Content="新增" Width="52" Style="{StaticResource TinyButton}" />
                                            <Button x:Name="ApplyRemoteTargetButton" Content="应用" Width="52" Style="{StaticResource TinyButton}" Margin="6,0,0,0" />
                                            <Button x:Name="DeleteRemoteTargetButton" Content="删除" Width="52" Style="{StaticResource DangerTinyButton}" Margin="6,0,0,0" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="目标 ID / 名称" Style="{StaticResource FieldLabel}" />
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBox x:Name="RemoteTargetLabelBox" Width="130" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <TextBox x:Name="RemoteTargetIdBox" />
                                        </DockPanel>
                                        <TextBlock Text="远端地址" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="RemoteTargetBaseUrlBox" Margin="0,0,0,8" />
                                        <DockPanel Margin="0,0,0,8">
                                            <CheckBox x:Name="RemoteTargetTokenSetBox" Content="已设置 Token" DockPanel.Dock="Right" />
                                            <CheckBox x:Name="RemoteTargetEnabledBox" Content="启用远端目标" />
                                        </DockPanel>
                                        <TextBlock Text="能力（每行一个）" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="RemoteTargetCapabilitiesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="54" Margin="0,0,0,10" />
                                        <TextBlock Text="导出 ID / Skill 名称" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="RemoteExportIdBox" Margin="0,0,0,8" />
                                        <TextBox x:Name="RemoteSkillNamesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="58" Margin="0,0,0,10" />
                                        <WrapPanel>
                                            <Button x:Name="ExportRemoteModuleButton" Content="导出远端包" Width="96" />
                                            <Button x:Name="PushRemoteModuleButton" Content="推送包" Width="72" Margin="8,0,0,0" />
                                            <Button x:Name="ExecuteRemoteModuleButton" Content="执行包" Width="72" Margin="8,0,0,0" />
                                            <Button x:Name="OpenRemoteExportsButton" Content="打开导出目录" Width="108" Margin="8,0,0,0" />
                                            <TextBlock x:Name="RemoteExportActionText" Text="--" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="10,8,0,0" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="AgentStatusPage" Visibility="Collapsed">
                                <TextBlock Text="集群状态与改进建议" Style="{StaticResource ManagementPageTitle}" />
                                <TextBlock Text="当前配置摘要和后续改进建议" Style="{StaticResource MutedText}" Margin="0,3,0,12" />
                                <TextBlock x:Name="AgentManagementSummaryText" Text="--" Foreground="{DynamicResource FantasyMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                <ListBox x:Name="AgentRecommendationsList" ItemTemplate="{StaticResource EventTemplate}" MaxHeight="300" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                
    </Grid>
</UserControl>
