<UserControl x:Class="SpiritKinDesktop.Controls.WorkbenchShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SpiritKinDesktop.Controls"
             xmlns:local="clr-namespace:SpiritKinDesktop"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
<Border Grid.Column="4" Background="{DynamicResource PanelBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="WorkbenchToolbarRowElement" Height="0" />
                    <RowDefinition x:Name="WorkbenchPanelRowElement" Height="*" MinHeight="220" />
                    <RowDefinition x:Name="AvatarSplitterRowElement" Height="0" />
                    <RowDefinition x:Name="AvatarPanelRowElement" Height="280" />
                </Grid.RowDefinitions>
                <Border x:Name="WorkbenchToolbarElement" Grid.Row="0" Background="{DynamicResource FantasySurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,6" Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="WebPreviewStatusTextElement" Text="桌面状态" Foreground="{DynamicResource FantasyHintTextBrush}" FontSize="12" VerticalAlignment="Center" DockPanel.Dock="Right" Visibility="Collapsed" />
                        <TextBlock x:Name="WorkbenchInstrumentSummaryElement"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="工作区仪表：本地变更 · 当前分支 · GitHub CLI"
                                   AutomationProperties.Name="工作区仪表摘要">
                            <Run Text="changes " Foreground="{DynamicResource FantasyMutedBrush}" />
                            <Run x:Name="InstrumentChangesRunElement" Text="0" Foreground="{DynamicResource FantasyCopperBrush}" FontWeight="SemiBold" />
                            <Run Text="   ·   分支 " Foreground="{DynamicResource FantasyMutedBrush}" />
                            <Run x:Name="InstrumentBranchRunElement" Text="master" Foreground="{DynamicResource FantasyTextBrush}" />
                            <Run Text="   ·   " Foreground="{DynamicResource FantasyMutedBrush}" />
                            <Run x:Name="InstrumentGhRunElement" Text="× gh" Foreground="{DynamicResource FantasyMutedBrush}" />
                        </TextBlock>
                    </DockPanel>
                </Border>
                <Border x:Name="AvatarPanelElement" Grid.Row="3" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0" Background="{DynamicResource FantasyCanvasBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="49" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource FantasySurfaceBrush}" Padding="12,6,12,7" ClipToBounds="False">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="3D 模型" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock Text="桌面嵌入视图" Style="{StaticResource MutedText}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="ReloadAvatarButtonElement" Content="刷新 3D" Width="76" Style="{StaticResource TinyButton}" />
                                    <Button x:Name="OpenAvatarButtonElement" Content="浮窗" Width="58" Style="{StaticResource TinyButton}" Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Padding="0" Background="{DynamicResource FantasyCanvasBrush}" ClipToBounds="True">
                            <Grid>
                                <wv2:WebView2 x:Name="AvatarViewElement" />
                                <Image x:Name="AvatarAnimationProxyElement"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"
                                       Stretch="Fill"
                                       SnapsToDevicePixels="True" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <!-- Keep the layout handle for collapse/reveal state, but the 3D region remains non-resizable. -->
                <GridSplitter x:Name="AvatarPanelSplitterElement"
                              Grid.Row="2"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              IsEnabled="False"
                              Focusable="False" />
                <Border x:Name="WorkbenchRestoreBarElement"
                        Grid.Row="1"
                        Panel.ZIndex="4"
                        Height="36"
                        VerticalAlignment="Top"
                        Visibility="Collapsed"
                        Background="{DynamicResource PanelBrush}"
                        BorderBrush="{DynamicResource FantasyCardBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,0">
                    <Button x:Name="RestoreWorkbenchPanelButtonElement"
                            Height="32"
                            MinHeight="32"
                            Padding="0"
                            Style="{StaticResource CodexSideButton}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            ToolTip="展开桌面状态"
                            AutomationProperties.Name="展开桌面状态">
                        <Grid>
                            <TextBlock Text="桌面状态"
                                       Foreground="{DynamicResource FantasyMutedBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{x:Static local:SemanticIcons.Expand}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="展开" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </Border>
                <Border x:Name="WorkbenchStatusPanelElement" Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,8,12,0">
                    <ScrollViewer x:Name="WorkbenchStatusScrollViewerElement" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Button x:Name="CollapseWorkbenchPanelButtonElement"
                                    Height="32"
                                    MinHeight="32"
                                    Padding="0"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource CodexSideButton}"
                                    HorizontalContentAlignment="Stretch"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    ToolTip="收起桌面状态"
                                    AutomationProperties.Name="收起桌面状态">
                                <Grid>
                                    <TextBlock Text="桌面状态" Foreground="{DynamicResource FantasyTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static local:SemanticIcons.Collapse}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <!-- v4 Atelier:右栏仪表去卡片化，靠底部分隔线分层（概念稿 .skin-atelier .status-card 去卡留底线）。 -->
                            <Border BorderBrush="{DynamicResource FantasyLineBrush}" BorderThickness="0,0,0,1" Background="Transparent" Padding="2,4,2,10" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="工作台" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource FantasyMutedBrush}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="WorkbenchWorkspaceHintTextElement"
                                                   Grid.Column="1"
                                                   Text="/ 安静仪表带"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="3,0,0,0" />
                                    </Grid>
                                    <TextBlock x:Name="WorkbenchWorkspaceRootTextElement" Text="当前项目工作区" Foreground="{DynamicResource FantasyTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="当前工作区" />
                                    <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                        <Button x:Name="OpenActiveWorkspaceButtonElement" Content="打开工作区" Height="28" MinWidth="88" Padding="10,0" Style="{StaticResource TinyButton}" />
                                        <Button x:Name="ManageActiveWorkspaceButtonElement" Content="管理项目" Height="28" MinWidth="78" Padding="10,0" Margin="8,0,0,0" Style="{StaticResource TinyButton}" />
                                    </StackPanel>
                                    <Grid Height="55" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- v4 Atelier:仪表格去卡片化，铜色左细条 + 无框仪表读数（概念稿 flat instrument）。 -->
                                        <Border Grid.Column="0" MinHeight="55" BorderThickness="0" Background="Transparent" Padding="10,6" Margin="0,0,5,0">
                                            <StackPanel>
                                                <TextBlock Text="127.0.0.1:8788" Foreground="{DynamicResource FantasyTextBrush}" FontSize="12" FontFamily="{StaticResource MonoFontFamily}" />
                                                <TextBlock Text="命令网关" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" MinHeight="55" BorderThickness="0" Background="Transparent" Padding="10,6" Margin="5,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="127.0.0.1:8765" Foreground="{DynamicResource FantasyTextBrush}" FontSize="12" FontFamily="{StaticResource MonoFontFamily}" />
                                                <TextBlock Text="事件通道" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Grid Height="55" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" MinHeight="55" BorderThickness="0" Background="Transparent" Padding="10,6" Margin="0,0,5,0">
                                            <StackPanel>
                                                <TextBlock Text="WPF" Foreground="{DynamicResource FantasyTextBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" />
                                                <TextBlock Text="official desktop" Style="{StaticResource MutedText}" FontSize="10" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" MinHeight="55" BorderThickness="0" Background="Transparent" Padding="10,6" Margin="5,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Live" Foreground="{DynamicResource FantasyTextBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" />
                                                <TextBlock Text="avatar runtime" Style="{StaticResource MutedText}" FontSize="10" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Expander x:Name="ProgressExpanderElement" Header="" Style="{StaticResource ManagementExpander}" IsExpanded="True"
                                      BorderThickness="0" Background="Transparent" Padding="2,0" Margin="0,14,0,6">
                                <Expander.Template>
                                    <ControlTemplate TargetType="Expander">
                                        <ContentPresenter x:Name="ProgressContent"
                                                          ContentSource="Content"
                                                          Visibility="Collapsed" />
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ProgressContent" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Expander.Template>
                                <Expander.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Height="0" />
                                    </DataTemplate>
                                </Expander.HeaderTemplate>
                                <Grid x:Name="WorkbenchProgressTrackElement" Margin="0" MaxHeight="124">
                                    <Border Width="1" Opacity="0.72" HorizontalAlignment="Left" Margin="5,4,0,4">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#70E99541" Offset="0" />
                                                <GradientStop Color="#28E99541" Offset="0.6" />
                                                <GradientStop Color="#00E99541" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Canvas IsHitTestVisible="False" Panel.ZIndex="2">
                                        <Border x:Name="WorkbenchRunPulseElement"
                                                Canvas.Left="4"
                                                Canvas.Top="0"
                                                Width="3"
                                                Height="26"
                                                CornerRadius="2"
                                                Opacity="0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#00E99541" Offset="0" />
                                                    <GradientStop Color="#FFF6DEB9" Offset="0.5" />
                                                    <GradientStop Color="#00E99541" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#E99541"
                                                                  BlurRadius="8"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.72" />
                                            </Border.Effect>
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="WorkbenchRunPulseTransformElement" />
                                            </Border.RenderTransform>
                                        </Border>
                                    </Canvas>
                                    <ListBox x:Name="WorkbenchProgressListElement" AlternationCount="2147483647" BorderThickness="0" Background="Transparent" Focusable="False" IsTabStop="False" RequestBringIntoView="WorkbenchProgressList_RequestBringIntoView" ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="EventNode" Width="7" Height="7" Fill="{DynamicResource FantasyCopperLineBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,5,0,0" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock x:Name="EventType" Text="{Binding Type}" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=(ItemsControl.AlternationIndex)}" Value="0">
                                                        <Setter TargetName="EventNode" Property="Fill" Value="{DynamicResource FantasyCopperBrush}" />
                                                        <Setter TargetName="EventNode" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#E99541" BlurRadius="10" ShadowDepth="0" Opacity="0.7" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter TargetName="EventType" Property="Foreground" Value="{DynamicResource FantasyTextBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Expander>

                            <Expander x:Name="EnvironmentExpanderElement" Header="环境" Style="{StaticResource ManagementExpander}" IsExpanded="False"
                                      BorderThickness="0" Background="Transparent" Padding="2,8" Margin="0,0,0,6">
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock x:Name="EnvironmentStatusTextElement" Text="--" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="8,0,0,8" />
                                    <Button x:Name="RefreshGitChangesButtonElement" Style="{StaticResource CodexSideButton}" Margin="0,0,0,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⊞" Foreground="{DynamicResource FantasyMutedBrush}" Width="22" FontSize="15" TextAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Text="变更" Foreground="{DynamicResource FantasyTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="LocalEnvironmentButtonElement" Style="{StaticResource CodexSideButton}" Margin="0,0,0,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▭" Foreground="{DynamicResource FantasyMutedBrush}" Width="22" FontSize="15" TextAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock x:Name="LocalEnvironmentTextElement" Text="本地" Foreground="{DynamicResource FantasyTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                            <TextBlock Text="⌄" Foreground="{DynamicResource FantasyHintTextBrush}" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BranchEnvironmentButtonElement" Style="{StaticResource CodexSideButton}" Margin="0,0,0,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⌘" Foreground="{DynamicResource FantasyMutedBrush}" Width="22" FontSize="15" TextAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock x:Name="BranchEnvironmentTextElement" Text="master" Foreground="{DynamicResource FantasyTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                            <TextBlock Text="⌄" Foreground="{DynamicResource FantasyHintTextBrush}" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="CommitPushButtonElement" Style="{StaticResource CodexSideButton}" Margin="0,0,0,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⟷" Foreground="{DynamicResource FantasyMutedBrush}" Width="22" FontSize="15" TextAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Text="提交或推送" Foreground="{DynamicResource FantasyTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="OpenTerminalButtonElement" Style="{StaticResource CodexSideButton}" Margin="0,2,0,0" AutomationProperties.Name="内置终端">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⌁" Foreground="{DynamicResource FantasyMutedBrush}" Width="22" FontSize="15" TextAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Text="终端" Foreground="{DynamicResource FantasyTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <DockPanel Margin="8,10,0,0">
                                        <TextBlock Text="◉" Foreground="{DynamicResource FantasyDisabledTextBrush}" FontSize="13" DockPanel.Dock="Left" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock x:Name="GitHubCliStatusTextElement" Text="GitHub CLI --" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </DockPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="变更" Style="{StaticResource ManagementExpander}" IsExpanded="True" Visibility="Collapsed">
                                <StackPanel Margin="0,8,0,0">
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button x:Name="ReviewChangesButtonElement" Content="查看" MinWidth="64" Height="28" MinHeight="28" Padding="8,0" Style="{StaticResource TinyButton}" />
                                        <Button x:Name="UndoSelectedChangeButtonElement" Content="撤销" MinWidth="64" Height="28" MinHeight="28" Padding="8,0" Style="{StaticResource TinyButton}" Margin="6,0,0,0" />
                                    </WrapPanel>
                                    <ListBox x:Name="GitChangesListElement" ItemTemplate="{StaticResource GitChangeTemplate}" SelectedValuePath="Path" BorderThickness="0" Background="{DynamicResource FantasySurfaceBrush}" MaxHeight="170" />
                                    <TextBox x:Name="ChangedFileDiffBoxElement" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Height="180" Margin="0,8,0,0" IsReadOnly="True" />
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="SourcesExpanderElement" Header="来源" Style="{StaticResource ManagementExpander}" IsExpanded="False"
                                      BorderThickness="0" Background="Transparent" Padding="2,8" Margin="0,0,0,6">
                                <Grid Margin="0,10,0,0">
                                    <TextBlock x:Name="SourcesEmptyTextElement" Text="暂无来源" Foreground="{DynamicResource FantasyDisabledTextBrush}" FontSize="13" Margin="8,0,0,0" />
                                    <ListBox x:Name="SourcesListElement" ItemTemplate="{StaticResource StatusEventTemplate}" BorderThickness="0" Background="Transparent" MaxHeight="150" Visibility="Collapsed" />
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <Grid x:Name="ManagementPanelHostElement" Grid.Row="2" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="RightNavColumnElement" Width="148" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource PanelAltBrush}" Padding="10,14">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <DockPanel>
                                    <Button x:Name="ToggleRightNavButtonElement" Content="‹" Width="30" Height="28" Style="{StaticResource TinyButton}" DockPanel.Dock="Right" Visibility="Collapsed" />
                                    <StackPanel x:Name="RightNavHeaderPanelElement">
                                        <TextBlock Text="管理中心" Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />
                                        <TextBlock x:Name="RightModuleTitleTextElement" Text="任务管理" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>
                            <ListBox x:Name="RightNavListElement" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource ModuleNavItem}">
                                <ListBoxItem IsHitTestVisible="False" Focusable="False" Padding="10,10,10,4">
                                    <TextBlock Text="核心工作" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="10.5" FontWeight="SemiBold" />
                                </ListBoxItem>
                                <ListBoxItem Content="项目总览" Tag="overview" />
                                <ListBoxItem Content="工作空间" Tag="tasks" IsSelected="True" />
                                <ListBoxItem Content="工作流" Tag="workflows" />
                                <ListBoxItem Content="模型协作" Tag="collaboration" />
                                <ListBoxItem Content="快速指令" Tag="commands" />
                                <ListBoxItem Content="每日事项" Tag="daily" />

                                <ListBoxItem IsHitTestVisible="False" Focusable="False" Padding="10,14,10,4">
                                    <TextBlock Text="智能与知识" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="10.5" FontWeight="SemiBold" />
                                </ListBoxItem>
                                <ListBoxItem Content="模型" Tag="models" />
                                <ListBoxItem Content="Agent 集群" Tag="agents" />
                                <ListBoxItem Content="Skills" Tag="skills" />
                                <ListBoxItem Content="MCP" Tag="mcp" />
                                <ListBoxItem Content="搜索与知识" Tag="search" />
                                <ListBoxItem Content="上下文" Tag="context" />
                                <ListBoxItem Content="学习与纠错" Tag="learning" />
                                <ListBoxItem Content="记忆复核" Tag="memory" />
                                <ListBoxItem Content="进化闭环" Tag="evolution" />

                                <ListBoxItem IsHitTestVisible="False" Focusable="False" Padding="10,14,10,4">
                                    <TextBlock Text="系统运行" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="10.5" FontWeight="SemiBold" />
                                </ListBoxItem>
                                <ListBoxItem Content="功能模块" Tag="modules" />
                                <ListBoxItem Content="授权与调度" Tag="governance" />
                                <ListBoxItem Content="移动端" Tag="mobile" />
                                <ListBoxItem Content="事件追踪" Tag="trace" />
                                <ListBoxItem Content="状态同步" Tag="sync" />
                                <ListBoxItem Content="服务与端口" Tag="services" />
                                <ListBoxItem Content="运行日志" Tag="logs" />
                                <ListBoxItem Content="诊断与修复" Tag="diagnostics" />
                            </ListBox>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource LineBrush}" />
                    <controls:ManagementPanelsView x:Name="ManagementPanelsElement" Grid.Column="2" Margin="20,16,18,16" />
                </Grid>
            </Grid>
        </Border>
        
</UserControl>

