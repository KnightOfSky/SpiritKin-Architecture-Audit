<UserControl x:Class="SpiritKinDesktop.Controls.GlobalSearchOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="OverlayElement"
            Background="{DynamicResource FantasyOverlayScrimBrush}"
            MouseDown="OverlayElement_MouseDown">
        <Border Width="720"
                MaxHeight="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,64,0,0"
                Background="{DynamicResource FantasySurfaceBrush}"
                BorderBrush="{DynamicResource FantasyBorderBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="14"
                MouseDown="PanelElement_MouseDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0">
                    <Button x:Name="GlobalSearchCloseButtonElement"
                            Content="×"
                            Width="30"
                            Height="28"
                            MinHeight="28"
                            Padding="0"
                            Style="{StaticResource TinyButton}"
                            DockPanel.Dock="Right"
                            AutomationProperties.Name="关闭搜索"
                            ToolTip="关闭搜索" />
                    <StackPanel>
                        <TextBlock Text="Search" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource FantasyPrimaryBrush}" />
                        <TextBlock x:Name="GlobalSearchSummaryTextElement"
                                   Text="查找功能、会话、任务、工作流、Skill、Agent、日志和配置项。"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </DockPanel>
                <TextBox x:Name="GlobalSearchBoxElement"
                         Grid.Row="2"
                         MinHeight="38"
                         FontSize="14"
                         TextChanged="GlobalSearchBoxElement_TextChanged"
                         PreviewKeyDown="GlobalSearchBoxElement_PreviewKeyDown"
                         ToolTip="Ctrl+F 打开搜索，Enter 定位，Esc 关闭" />
                <Border Grid.Row="4"
                        BorderBrush="{DynamicResource FantasyLineBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource FantasyListAltBrush}"
                        CornerRadius="6"
                        Padding="4">
                    <Grid>
                        <TextBlock x:Name="GlobalSearchEmptyTextElement"
                                   Text="输入关键词开始搜索。"
                                   Style="{StaticResource MutedText}"
                                   Margin="10,8,0,0" />
                        <ListBox x:Name="GlobalSearchResultsListElement"
                                 ItemTemplate="{StaticResource GlobalSearchResultTemplate}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MaxHeight="440"
                                 MouseDoubleClick="GlobalSearchResultsListElement_MouseDoubleClick"
                                 PreviewKeyDown="GlobalSearchResultsListElement_PreviewKeyDown" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>
