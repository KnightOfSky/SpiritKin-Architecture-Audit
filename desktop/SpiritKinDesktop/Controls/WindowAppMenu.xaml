<UserControl x:Class="SpiritKinDesktop.Controls.WindowAppMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Menu VerticalAlignment="Center">
        <MenuItem Header="文件">
            <MenuItem Header="新会话" Click="NewChat_Click" />
            <MenuItem Header="新项目" Click="NewProject_Click" />
            <Separator />
            <MenuItem Header="打开工作区" Click="OpenWorkspace_Click" />
            <MenuItem Header="全部刷新" Click="RefreshAll_Click" />
            <Separator />
            <MenuItem Header="退出" Click="Exit_Click" />
        </MenuItem>
        <MenuItem Header="编辑">
            <MenuItem Header="撤销" InputGestureText="Ctrl+Z" Click="Undo_Click" />
            <MenuItem Header="查找" InputGestureText="Ctrl+F" Click="Find_Click" />
            <MenuItem Header="删除选中项" InputGestureText="Del" Click="Delete_Click" />
            <Separator />
            <MenuItem Header="剪切" Click="Cut_Click" />
            <MenuItem Header="复制" Click="Copy_Click" />
            <MenuItem Header="粘贴" Click="Paste_Click" />
            <Separator />
            <MenuItem Header="全选" Click="SelectAll_Click" />
        </MenuItem>
        <MenuItem Header="视图">
            <MenuItem Header="快速会话" Click="QuickChat_Click" />
            <MenuItem Header="语音通话" Click="VoiceCall_Click" />
            <MenuItem Header="音乐播放器" Click="MusicPlayer_Click" />
            <MenuItem Header="管理" Click="Management_Click" />
            <Separator />
            <MenuItem x:Name="DesktopTtsMenuItem" Header="桌面 TTS" IsCheckable="True" Click="ToggleDesktopTts_Click" />
            <Separator />
            <MenuItem Header="外观主题">
                <MenuItem x:Name="ThemeSystemMenuItem" Header="跟随系统" IsCheckable="True" Click="ThemeSystem_Click" />
                <MenuItem x:Name="ThemeLightMenuItem" Header="日间" IsCheckable="True" Click="ThemeLight_Click" />
                <MenuItem x:Name="ThemeDarkMenuItem" Header="夜间" IsCheckable="True" Click="ThemeDark_Click" />
            </MenuItem>
            <Separator />
            <MenuItem Header="活动会话" Click="ShowActiveChats_Click" />
            <MenuItem Header="归档会话" Click="ShowArchivedChats_Click" />
            <MenuItem Header="全部会话" Click="ShowAllChats_Click" />
            <Separator />
            <MenuItem Header="任务" Click="OpenTasks_Click" />
            <MenuItem Header="项目" Click="OpenProjects_Click" />
            <MenuItem Header="快捷指令" Click="OpenCommands_Click" />
            <MenuItem Header="协助模型" Click="OpenModels_Click" />
        </MenuItem>
        <MenuItem Header="窗口">
            <MenuItem Header="最小化" Click="Minimize_Click" />
            <MenuItem Header="最大化 / 还原" Click="MaximizeRestore_Click" />
            <Separator />
            <MenuItem Header="刷新 3D" Click="RefreshAvatar_Click" />
            <MenuItem Header="浮动 3D" Click="FloatAvatar_Click" />
        </MenuItem>
        <MenuItem Header="帮助">
            <MenuItem Header="诊断" Click="OpenDiagnostics_Click" />
            <MenuItem Header="日志" Click="OpenLogs_Click" />
            <MenuItem Header="服务" Click="OpenServices_Click" />
            <Separator />
            <MenuItem Header="关于 SpiritKin" Click="About_Click" />
        </MenuItem>
    </Menu>
</UserControl>
