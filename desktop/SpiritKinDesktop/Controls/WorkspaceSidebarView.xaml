<UserControl x:Class="SpiritKinDesktop.Controls.WorkspaceSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SpiritKinDesktop.Controls"
             xmlns:local="clr-namespace:SpiritKinDesktop"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
<Border Grid.Column="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="68" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="SidebarListRowElement" Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="13,5,14,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="5"
                                HorizontalAlignment="Left" VerticalAlignment="Center" Margin="1,0,0,0"
                                Background="{DynamicResource FantasyBrandAccentBrush}">
                            <Border.LayoutTransform>
                                <RotateTransform Angle="45" />
                            </Border.LayoutTransform>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SpiritKin" FontFamily="{StaticResource BrandLatinFontFamily}" FontSize="20" FontWeight="Black" Foreground="{DynamicResource FantasyTextBrush}" LineHeight="24" LineStackingStrategy="BlockLineHeight" />
                            </StackPanel>
                            <TextBlock Text="桌面工作台" Foreground="{DynamicResource AtelierFaintTextBrush}" FontSize="12" LineHeight="14" LineStackingStrategy="BlockLineHeight" />
                            <TextBlock x:Name="WorkspaceRootTextElement" Text="工作区：--" Foreground="{DynamicResource AtelierFaintTextBrush}" FontSize="12" LineHeight="14" LineStackingStrategy="BlockLineHeight" TextTrimming="CharacterEllipsis" MaxWidth="145" ToolTip="当前桌面端工作区" />
                        </StackPanel>
                        <Ellipse x:Name="SyncDotElement" Grid.Column="2" Width="9" Height="9" Fill="{DynamicResource FantasyScrollHoverBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                    <StackPanel Grid.Row="1" Margin="12,10,12,8">
                        <ListBox x:Name="WorkspaceNavListElement" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource ModuleNavItem}" Margin="0,0,0,10" MouseLeftButtonUp="WorkspaceNavList_MouseLeftButtonUp">
                            <ListBoxItem Content="快速会话" Tag="chat" IsSelected="True" />
                            <ListBoxItem Content="管理" Tag="management" />
                        </ListBox>
                    <StackPanel Visibility="Collapsed">
                        <TextBox x:Name="ApiUrlBoxElement" />
                        <TextBox x:Name="WsUrlBoxElement" />
                        <PasswordBox x:Name="TokenBoxElement" />
                        <Button x:Name="RefreshButtonElement" Content="刷新" />
                        <Button x:Name="NewSessionButtonElement" Content="新会话" />
                    </StackPanel>
                    <TextBlock x:Name="ConnectionStatusTextElement" Text="未连接" Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="104" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="会话显示" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0" />
                        <ComboBox x:Name="SessionFilterBoxElement" Grid.Column="1">
                            <ComboBoxItem Content="活动" Tag="active" IsSelected="True" />
                            <ComboBoxItem Content="归档" Tag="archived" />
                            <ComboBoxItem Content="全部" Tag="all" />
                        </ComboBox>
                    </Grid>
                    <TextBlock x:Name="SessionFilterSummaryTextElement" Text="活动 0 · 归档 0" Style="{StaticResource MutedText}" Margin="0,5,0,0" Visibility="Collapsed" />
                </StackPanel>
                <ScrollViewer Grid.Row="2"
                              Margin="12,0,10,0"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ProjectsSummaryTextElement" Text="项目 · 活动 0 · 归档 0" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0" />
                            <Button x:Name="ProjectsMenuButtonElement" Grid.Column="1" Content="..." Width="28" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" Margin="0,0,6,0" AutomationProperties.Name="项目操作菜单" ToolTip="项目操作" />
                            <Button x:Name="ToggleProjectsButtonElement" Grid.Column="2" Content="⌄" Width="24" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" Margin="0,0,6,0" AutomationProperties.Name="展开或收起项目列表" ToolTip="展开或收起项目列表" />
                            <Button x:Name="NewProjectSidebarButtonElement" Grid.Column="3" Content="+" Width="24" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" AutomationProperties.Name="新建项目" ToolTip="新建项目" />
                        </Grid>
                        <ListBox x:Name="ProjectsListElement" ItemTemplate="{StaticResource ProjectTemplate}" SelectedValuePath="Id" SelectionChanged="ProjectsList_SelectionChanged" MouseLeftButtonUp="ProjectsList_MouseLeftButtonUp" BorderThickness="0" Background="Transparent" Height="Auto" MaxHeight="240" />
                        <Border Height="1" Background="{DynamicResource FantasyLineBrush}" Margin="0,12,0,12" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ChatsSummaryTextElement" Text="会话 · 活动 0 · 归档 0" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0" />
                            <Button x:Name="ChatsMenuButtonElement" Grid.Column="1" Content="..." Width="28" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" Margin="0,0,6,0" AutomationProperties.Name="会话操作菜单" ToolTip="会话操作" />
                            <Button x:Name="ToggleChatsButtonElement" Grid.Column="2" Content="⌄" Width="24" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" Margin="0,0,6,0" AutomationProperties.Name="展开或收起会话列表" ToolTip="展开或收起会话列表" />
                            <Button x:Name="NewStandaloneSessionButtonElement" Grid.Column="3" Content="+" Width="24" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" AutomationProperties.Name="新建独立会话" ToolTip="新建独立会话" />
                        </Grid>
                        <ListBox x:Name="SessionsListElement" ItemTemplate="{StaticResource SessionTemplate}" SelectedValuePath="Id" SelectionChanged="SessionsList_SelectionChanged" BorderThickness="0" Background="Transparent" />
                        <Border Height="1" Background="{DynamicResource FantasyLineBrush}" Margin="0,12,0,12" Visibility="Collapsed" />
                        <Grid Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="模型协作对话" Style="{StaticResource SectionHeader}" TextTrimming="CharacterEllipsis" Margin="0" />
                                <TextBlock x:Name="CollaborationChatSummaryTextElement"
                                           Text="0 个协作线程 · 0 条"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button x:Name="CollaborationMenuButtonElement" Grid.Column="1" Content="..." Width="28" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" Margin="0,0,6,0" AutomationProperties.Name="协作操作菜单" ToolTip="协作操作" />
                            <Button x:Name="ToggleCollaborationButtonElement" Grid.Column="2" Content="⌄" Width="24" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" Margin="0,0,6,0" AutomationProperties.Name="展开或收起协作列表" ToolTip="展开或收起协作列表" />
                            <Button x:Name="NewCollaborationThreadButtonElement" Grid.Column="3" Content="+" Width="24" Height="24" Padding="0" MinHeight="24" Style="{StaticResource TinyButton}" HorizontalAlignment="Right" AutomationProperties.Name="新建协作线程" ToolTip="新建协作线程" />
                        </Grid>
                        <StackPanel x:Name="CollaborationBodyPanelElement" Visibility="Collapsed">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="绑定项目"
                                           Style="{StaticResource MutedText}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0" />
                                <TextBlock x:Name="CollaborationChatUnreadTextElement"
                                           Grid.Column="1"
                                           Text=""
                                           Foreground="{DynamicResource FantasyPrimaryBrush}"
                                           FontSize="12"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <ComboBox x:Name="CollaborationProjectScopeBoxElement"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Title"
                                      SelectionChanged="CollaborationProjectScopeBox_SelectionChanged"
                                      Margin="0,0,0,6"
                                      ToolTip="选择协作要绑定的项目；选择 Chats 表示普通会话范围" />
                            <TextBlock Text="绑定会话"
                                       Style="{StaticResource MutedText}"
                                       FontSize="11"
                                       Margin="0,0,0,3" />
                            <ComboBox x:Name="CollaborationSessionScopeBoxElement"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Title"
                                      SelectionChanged="CollaborationSessionScopeBox_SelectionChanged"
                                      Margin="0,0,0,8"
                                      ToolTip="选择项目全部会话或项目内某个会话；下面协作线程仍用于具体模型对话话题" />
                            <ComboBox x:Name="CollaborationContextBoxElement"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Title"
                                      SelectionChanged="CollaborationContextBox_SelectionChanged"
                                      Visibility="Collapsed" />
                            <TextBlock Text="协作线程"
                                       Style="{StaticResource MutedText}"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        <ListBox x:Name="CollaborationThreadsListElement"
                                 SelectedValuePath="Id"
                                 SelectionChanged="CollaborationThreadsList_SelectionChanged"
                                 MouseLeftButtonUp="CollaborationThreadsList_MouseLeftButtonUp"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0,6,0,0"
                                 MaxHeight="190">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" Padding="8,6" Margin="0,0,0,2">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="打开协作线程" Click="CollaborationThreadOpenMenu_Click" Tag="{Binding}" />
                                                <MenuItem Header="{Binding ArchiveActionLabel}" Click="CollaborationThreadArchiveMenu_Click" Tag="{Binding}" />
                                                <MenuItem Header="删除协作线程" Click="CollaborationThreadDeleteMenu_Click" Tag="{Binding}" />
                                                <Separator />
                                                <MenuItem Header="复制线程 ID" Click="CollaborationThreadCopyIdMenu_Click" Tag="{Binding}" />
                                                <MenuItem Header="打开协作管理" Click="CollaborationThreadOpenManagementMenu_Click" Tag="{Binding}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="12" Margin="8,0,0,0" />
                                            </Grid>
                                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                <Grid Grid.Row="3">
                    <Border BorderBrush="{DynamicResource FantasyLineBrush}" BorderThickness="0,1,0,0" Padding="13,8,13,21" Background="{DynamicResource PanelBrush}">
                        <StackPanel>
                            <TextBlock Text="后端功能映射" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,13">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="chat" Foreground="{DynamicResource FantasyTextBrush}" FontSize="10" />
                                <TextBlock Grid.Column="1" Text="append_message" Foreground="{DynamicResource FantasyCopperBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="10" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,0,0,13">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="workflow" Foreground="{DynamicResource FantasyTextBrush}" FontSize="10" />
                                <TextBlock Grid.Column="1" Text="start_workflow_run" Foreground="{DynamicResource FantasyCopperBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="10" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,0,0,13">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="3D" Foreground="{DynamicResource FantasyTextBrush}" FontSize="10" />
                                <TextBlock Grid.Column="1" Text="avatar_state_event" Foreground="{DynamicResource FantasyCopperBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="10" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="mobile" Foreground="{DynamicResource FantasyTextBrush}" FontSize="10" />
                                <TextBlock Grid.Column="1" Text="queue_android_command" Foreground="{DynamicResource FantasyCopperBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="10" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <StackPanel Visibility="Collapsed">
                        <Button x:Name="RefreshSessionsButtonElement" Content="刷新" />
                        <Button x:Name="DeleteActiveSessionButtonElement" Content="删除" Style="{StaticResource DangerButton}" />
                        <Button x:Name="AddProjectButtonElement" Content="添加" />
                        <TextBox x:Name="ProjectTitleBoxElement" />
                        <Button x:Name="AddTaskButtonElement" Content="添加" />
                        <TextBox x:Name="TaskTitleBoxElement" />
                        <ListBox x:Name="TasksListElement" ItemTemplate="{StaticResource TaskTemplate}" SelectedValuePath="Id" SelectionChanged="TasksList_SelectionChanged" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        
</UserControl>

