<ResourceDictionary x:Class="SpiritKinDesktop.MainWindowInteractionTemplates"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SpiritKinDesktop">
        <DataTemplate x:Key="SessionTemplate">
            <Border Background="Transparent" Padding="8,7" Margin="0"
                    HorizontalAlignment="Stretch">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="{Binding PinActionLabel}" Click="SessionPinMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="重命名会话" Click="SessionRenameMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="{Binding ArchiveActionLabel}" Click="SessionArchiveMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="{Binding UnreadActionLabel}" Click="SessionUnreadMenu_Click" Tag="{Binding}" />
                        <Separator />
                        <MenuItem Header="在资源管理器中打开" Click="SessionOpenExplorerMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="复制工作目录" Click="SessionCopyWorkingDirMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="复制会话 ID" Click="SessionCopyIdMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="复制 deeplink" Click="SessionCopyDeeplinkMenu_Click" Tag="{Binding}" />
                        <Separator />
                        <MenuItem Header="删除会话" Click="SessionDeleteMenu_Click" Tag="{Binding}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="12" Margin="8,0,0,0" />
                    </Grid>
                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ManagedSessionTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8" MinHeight="58">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="置顶会话" Click="ProjectSessionPinMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="重命名会话" Click="ProjectSessionRenameMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="{Binding ArchiveActionLabel}" Click="ProjectSessionArchiveMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="{Binding UnreadActionLabel}" Click="ProjectSessionUnreadMenu_Click" Tag="{Binding}" />
                        <Separator />
                        <MenuItem Header="在资源管理器中打开" Click="SidebarOpenExplorerMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="复制工作目录" Click="SidebarCopyWorkingDirMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="复制 ID" Click="SidebarCopyIdMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="复制 deeplink" Click="SidebarCopyDeeplinkMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="删除" Click="SidebarDeleteMenu_Click" Tag="{Binding}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ProjectTemplate">
            <Border Background="Transparent" Padding="{Binding ItemPadding}" Margin="0"
                    HorizontalAlignment="Stretch">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="新建项目会话" Click="ProjectNewChatMenu_Click" Tag="{Binding}" Visibility="{Binding ProjectActionVisibility}" />
                        <MenuItem Header="重命名项目" Click="ProjectRenameMenu_Click" Tag="{Binding}" Visibility="{Binding ProjectActionVisibility}" />
                        <MenuItem Header="{Binding ArchiveActionLabel}" Click="ProjectArchiveMenu_Click" Tag="{Binding}" Visibility="{Binding ProjectActionVisibility}" />
                        <MenuItem Header="打开项目管理" Click="ProjectOpenManagementMenu_Click" Tag="{Binding}" Visibility="{Binding ProjectActionVisibility}" />
                        <MenuItem Header="在资源管理器中打开" Click="SidebarOpenExplorerMenu_Click" Tag="{Binding}" Visibility="{Binding ProjectActionVisibility}" />
                        <MenuItem Header="复制工作目录" Click="SidebarCopyWorkingDirMenu_Click" Tag="{Binding}" Visibility="{Binding ProjectActionVisibility}" />
                        <MenuItem Header="置顶会话" Click="ProjectSessionPinMenu_Click" Tag="{Binding}" Visibility="{Binding SessionActionVisibility}" />
                        <Separator />
                        <MenuItem Header="重命名会话" Click="ProjectSessionRenameMenu_Click" Tag="{Binding}" Visibility="{Binding SessionActionVisibility}" />
                        <MenuItem Header="{Binding ArchiveActionLabel}" Click="ProjectSessionArchiveMenu_Click" Tag="{Binding}" Visibility="{Binding SessionActionVisibility}" />
                        <MenuItem Header="{Binding UnreadActionLabel}" Click="ProjectSessionUnreadMenu_Click" Tag="{Binding}" Visibility="{Binding SessionActionVisibility}" />
                        <MenuItem Header="在资源管理器中打开" Click="SidebarOpenExplorerMenu_Click" Tag="{Binding}" Visibility="{Binding SessionActionVisibility}" />
                        <MenuItem Header="复制工作目录" Click="SidebarCopyWorkingDirMenu_Click" Tag="{Binding}" Visibility="{Binding SessionActionVisibility}" />
                        <MenuItem Header="复制 ID" Click="SidebarCopyIdMenu_Click" Tag="{Binding}" />
                        <MenuItem Header="复制 deeplink" Click="SidebarCopyDeeplinkMenu_Click" Tag="{Binding}" Visibility="{Binding SessionActionVisibility}" />
                        <MenuItem Header="删除" Click="SidebarDeleteMenu_Click" Tag="{Binding}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Glyph}" Foreground="{DynamicResource FantasyPrimaryBrush}" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="{Binding TitleWeight}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="12" Margin="8,0,0,0" />
                    </Grid>
                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" Margin="18,3,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="TaskTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1"
                                    BorderBrush="{Binding StatusBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource FantasyListAltBrush}"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                            <Button Content="开始" Tag="{Binding Id}" Click="TaskStart_Click" Height="28" Padding="8,3" />
                            <Button Content="完成" Tag="{Binding Id}" Click="TaskComplete_Click" Height="28" Padding="8,3" Margin="6,0,0,0" />
                            <Button Content="阻塞" Tag="{Binding Id}" Click="TaskBlocked_Click" Height="28" Padding="8,3" Margin="6,0,0,0" />
                            <Button Content="删除" Tag="{Binding Id}" Click="TaskDelete_Click" Height="28" Padding="8,3" Margin="6,0,0,0" Style="{StaticResource DangerTinyButton}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowGraphEdgeTemplate">
            <Grid Background="Transparent">
                <Path Data="{Binding Geometry}"
                      Stroke="Transparent"
                      StrokeThickness="16"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Cursor="Hand"
                      Tag="{Binding}"
                      MouseLeftButtonDown="WorkflowGraphEdge_MouseLeftButtonDown"
                      ToolTip="{Binding ToolTip}">
                    <Path.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="{Binding EditNoteLabel}" Click="WorkflowGraphEdgeEditNoteMenu_Click" Tag="{Binding}" />
                            <MenuItem Header="{Binding BreakLinkLabel}" Click="WorkflowGraphEdgeBreakMenu_Click" Tag="{Binding}" />
                        </ContextMenu>
                    </Path.ContextMenu>
                </Path>
                <Path Data="{Binding Geometry}"
                      Stroke="{Binding StrokeBrush}"
                      StrokeThickness="{Binding StrokeThickness}"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Opacity="{Binding Opacity}"
                      SnapsToDevicePixels="False"
                      UseLayoutRounding="False"
                      RenderOptions.EdgeMode="Unspecified"
                      IsHitTestVisible="False" />
                <Border Background="{DynamicResource FantasyListAltBrush}"
                        BorderBrush="{Binding StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="5,1"
                        Margin="{Binding LabelMargin}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False"
                        Visibility="{Binding LabelVisibility}">
                    <TextBlock Text="{Binding Label}"
                               Foreground="{DynamicResource FantasyMutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="170" />
                </Border>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowInputPinTemplate">
            <Grid Height="23"
                  Margin="0,0,0,3"
                  ToolTip="{Binding ToolTip}"
                  Cursor="Cross"
                  MouseLeftButtonUp="WorkflowGraphInputPort_MouseLeftButtonUp">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="98" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Ellipse Width="15"
                         Height="15"
                         Fill="{Binding Brush}"
                         Stroke="{Binding StrokeBrush}"
                         StrokeThickness="{Binding StrokeThickness}"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center" />
                <Border Grid.Column="1"
                        BorderBrush="{Binding StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="4,1"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource FantasyListAltBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSource}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasyWarningWashBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding Compatible}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasySuccessWashBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding Incompatible}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasyDangerWashBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding DisplayLabel}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource FantasyMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSource}" Value="True"><Setter Property="Foreground" Value="{DynamicResource FantasyWarningTextBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding Compatible}" Value="True"><Setter Property="Foreground" Value="{DynamicResource FantasySuccessTextBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding Incompatible}" Value="True"><Setter Property="Foreground" Value="{DynamicResource FantasyDangerTextBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowOutputPinTemplate">
            <Grid Height="23"
                  Margin="0,0,0,3"
                  ToolTip="{Binding ToolTip}"
                  Cursor="Cross"
                  MouseLeftButtonDown="WorkflowGraphOutputPort_MouseLeftButtonDown"
                  MouseMove="WorkflowGraphOutputPort_MouseMove"
                  MouseLeftButtonUp="WorkflowGraphOutputPort_MouseLeftButtonUp">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="98" />
                    <ColumnDefinition Width="15" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="1"
                        BorderBrush="{Binding StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="4,1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource FantasyListAltBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSource}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasyWarningWashBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding Compatible}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasySuccessWashBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding Incompatible}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasyDangerWashBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding DisplayLabel}" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource FantasyMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSource}" Value="True"><Setter Property="Foreground" Value="{DynamicResource FantasyWarningTextBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding Compatible}" Value="True"><Setter Property="Foreground" Value="{DynamicResource FantasySuccessTextBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding Incompatible}" Value="True"><Setter Property="Foreground" Value="{DynamicResource FantasyDangerTextBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <Ellipse Grid.Column="2"
                         Width="15"
                         Height="15"
                         Fill="{Binding Brush}"
                         Stroke="{Binding StrokeBrush}"
                         StrokeThickness="{Binding StrokeThickness}"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowGraphNodeTemplate">
            <Border Width="248"
                    Height="190"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding BorderThickness}"
                    Padding="0"
                    CornerRadius="6"
                    Effect="{Binding ShadowEffect}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    MouseLeftButtonDown="WorkflowGraphNode_MouseLeftButtonDown"
                    MouseMove="WorkflowGraphNode_MouseMove"
                    MouseLeftButtonUp="WorkflowGraphNode_MouseLeftButtonUp"
                    Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource FantasySurfaceBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Runnable}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasyWarningWashBrush}" /></DataTrigger>
                            <DataTrigger Binding="{Binding Selected}" Value="True"><Setter Property="Background" Value="{DynamicResource FantasyGoldWashBrush}" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="编辑节点属性" Click="WorkflowGraphNodeEditMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="应用右侧属性到草稿" Click="WorkflowGraphNodeApplyInspectorMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="设为连线源" Click="WorkflowGraphNodeConnectSourceMenu_Click" Tag="{Binding NodeId}" />
                        <Separator />
                        <MenuItem Header="新增下游智能体节点" Click="WorkflowGraphNodeAddAgentChildMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="新增下游工具节点" Click="WorkflowGraphNodeAddToolChildMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="新增下游技能节点" Click="WorkflowGraphNodeAddSkillChildMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="新增下游审核门禁" Click="WorkflowGraphNodeAddReviewChildMenu_Click" Tag="{Binding NodeId}" />
                        <Separator />
                        <MenuItem Header="新增下游条件分支" Click="WorkflowGraphNodeAddBranchChildMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="新增下游等待信号" Click="WorkflowGraphNodeAddWaiterChildMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="新增下游外部回调" Click="WorkflowGraphNodeAddCallbackChildMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="新增下游子工作流" Click="WorkflowGraphNodeAddSubgraphChildMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="新增下游自定义节点" Click="WorkflowGraphNodeAddCustomChildMenu_Click" Tag="{Binding NodeId}" />
                        <Separator />
                        <MenuItem Header="复制节点" Click="WorkflowGraphNodeDuplicateMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="断开输入依赖" Click="WorkflowGraphNodeDisconnectInputsMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="断开输出连线" Click="WorkflowGraphNodeDisconnectOutputsMenu_Click" Tag="{Binding NodeId}" />
                        <Separator />
                        <MenuItem Header="诊断 / 自修复建议" Click="WorkflowGraphNodeRepairMenu_Click" Tag="{Binding NodeId}" />
                        <MenuItem Header="删除节点" Click="WorkflowGraphNodeDeleteMenu_Click" Tag="{Binding NodeId}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="78" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="10,10,10,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource FantasyTextBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                <Border Grid.Column="1"
                                        BorderBrush="{Binding StatusBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource PanelAltBrush}"
                                        CornerRadius="4"
                                        Padding="5,1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding InputPins}" ItemTemplate="{StaticResource WorkflowInputPinTemplate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <ItemsControl ItemsSource="{Binding OutputPins}" ItemTemplate="{StaticResource WorkflowOutputPinTemplate}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="2" Margin="10,2,10,0" />
                    <Grid Grid.Row="3" Margin="10,0,10,6" IsHitTestVisible="False">
                        <TextBlock Text="{Binding ActorLine}"
                                   Foreground="{DynamicResource FantasyTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="GitChangeTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8" Tag="{Binding Path}" MouseEnter="GitChangeItem_MouseEnter">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Path}" Foreground="{DynamicResource FantasyTextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1" BorderBrush="{DynamicResource FantasySuccessBrush}" BorderThickness="1" Background="{DynamicResource FantasySuccessWashBrush}" CornerRadius="999" Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Delta}" Foreground="{DynamicResource FantasySuccessBrush}" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ComposerAttachmentTemplate">
            <Border Width="76"
                    Height="76"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource FantasyLineBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource FantasyMediaCanvasBrush}"
                    Margin="0,0,8,8"
                    ClipToBounds="True"
                    ToolTip="{Binding Tooltip}">
                <Grid>
                    <Image Source="{Binding ThumbnailPath}" Stretch="Uniform" Visibility="{Binding ThumbnailVisibility}" Margin="4" />
                    <StackPanel Visibility="{Binding FileVisibility}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6">
                        <TextBlock Text="{Binding Icon}" Foreground="{DynamicResource FantasyMediaIconBrush}" FontSize="19" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Extension}" Foreground="{DynamicResource FantasyMediaIconBrush}" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border VerticalAlignment="Bottom" Background="{DynamicResource FantasyMediaScrimBrush}" Padding="5,3">
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource FantasyMediaTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Button Content="×"
                            Tag="{Binding FileId}"
                            Click="RemoveAttachmentButton_Click"
                            Style="{StaticResource AttachmentRemoveButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,4,4,0"
                            AutomationProperties.Name="移除附件"
                            ToolTip="移除附件" />
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ServiceTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                            <Button Content="启动" Tag="{Binding ServiceId}" Click="ServiceStart_Click" Height="28" Padding="8,3" />
                            <Button Content="重启" Tag="{Binding ServiceId}" Click="ServiceRestart_Click" Height="28" Padding="8,3" Margin="6,0,0,0" />
                            <Button Content="停止" Tag="{Binding ServiceId}" Click="ServiceStop_Click" Height="28" Padding="8,3" Margin="6,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MessageTemplate">
            <Grid x:Name="MessageRoot" Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding Alignment}"
                  Tag="{Binding Id}"
                  MouseEnter="MessageItem_MouseEnter">
                <Grid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="复制消息" Click="MessageCopyMenu_Click" Visibility="{Binding CopyVisibility}" />
                        <MenuItem Header="编辑" Click="MessageEditMenu_Click" Visibility="{Binding EditVisibility}" />
                        <MenuItem Header="Fork 到这里" Click="MessageForkMenu_Click" Visibility="{Binding ForkVisibility}" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border x:Name="MessageBubble"
                        Grid.Row="0"
                        Width="{Binding BubbleWidth}"
                        MaxWidth="{Binding MaxWidth}"
                        HorizontalAlignment="{Binding Alignment}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="{Binding BorderThickness}"
                        Background="{Binding Background}"
                        Padding="{Binding Padding}"
                        Effect="{Binding BubbleEffect}"
                        CornerRadius="{Binding CornerRadius}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Visibility="{Binding HeaderVisibility}" MinHeight="19" Margin="0,1,0,7" HorizontalAlignment="{Binding HeaderAlignment}">
                            <TextBlock Text="{Binding Meta}" Style="{StaticResource AtelierMessageSpeakerText}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding DurationText}" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="12" DockPanel.Dock="Right" VerticalAlignment="Center" />
                        </DockPanel>
                        <Grid Grid.Row="1" Visibility="{Binding TextVisibility}">
                            <TextBox Text="{Binding Text, Mode=OneWay}"
                                     FontSize="{Binding TextSize}"
                                     TextAlignment="{Binding MessageTextAlignment}"
                                     TextBlock.LineHeight="{Binding LineHeight}"
                                     MaxHeight="{Binding TextMaxHeight}"
                                     VerticalScrollBarVisibility="Hidden">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MessageTextBox}">
                                        <Setter Property="Foreground" Value="{DynamicResource FantasyTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource FantasyFaintTextBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                        <Grid Grid.Row="1" Visibility="{Binding EditPanelVisibility}" MinWidth="520">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="74"
                                     MaxHeight="180"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource FantasyTextBrush}"
                                     CaretBrush="{DynamicResource FantasyPrimaryBrush}"
                                     Padding="0"
                                     FontSize="{Binding TextSize}" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="取消"
                                        Tag="{Binding Id}"
                                        Click="MessageCancelEditButton_Click"
                                        Style="{StaticResource InlineEditButton}"
                                        Background="{DynamicResource FantasySurfaceBrush}"
                                        BorderBrush="{DynamicResource FantasyLineBrush}" />
                                <Button Content="发送"
                                        Tag="{Binding Id}"
                                        Click="MessageSendEditButton_Click"
                                        Style="{StaticResource InlineEditButton}"
                                        Background="{DynamicResource FantasyTextBrush}"
                                        BorderBrush="{DynamicResource FantasyTextBrush}"
                                        Foreground="{DynamicResource FantasySurfaceBrush}"
                                        Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel Orientation="Horizontal"
                            Grid.Row="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Panel.ZIndex="3"
                            Margin="0,4,2,0"
                            Visibility="{Binding ActionVisibility}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=MessageRoot, Path=IsMouseOver}" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="{Binding ExpandTextLabel}"
                            Tag="{Binding Id}"
                            Click="MessageExpandButton_Click"
                            Style="{StaticResource MessageActionButton}"
                            Visibility="{Binding ExpandTextVisibility}"
                            MinWidth="58"
                            Padding="7,0"
                            ToolTip="展开或收起完整消息" />
                    <Button Content="{Binding CopyLabel}"
                            Width="{Binding ActionButtonWidth}"
                            Tag="{Binding Id}"
                            Click="MessageCopyButton_Click"
                            Style="{StaticResource MessageActionButton}"
                            Visibility="{Binding CopyVisibility}"
                            ToolTip="复制消息" />
                    <Button Content="{Binding EditLabel}"
                            Width="{Binding ActionButtonWidth}"
                            Tag="{Binding Id}"
                            Click="MessageEditButton_Click"
                            Style="{StaticResource MessageActionButton}"
                            Margin="5,0,0,0"
                            Visibility="{Binding EditVisibility}"
                            ToolTip="编辑" />
                    <Button Content="{Binding ForkLabel}"
                            Width="{Binding ActionButtonWidth}"
                            Tag="{Binding Id}"
                            Click="MessageForkButton_Click"
                            Style="{StaticResource MessageActionButton}"
                            Margin="5,0,0,0"
                            Visibility="{Binding ForkVisibility}"
                            ToolTip="从这里 Fork 会话" />
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:MessageViewModel}">
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource MessageTemplate}" />
        </DataTemplate>
        <DataTemplate x:Key="WorkNarrativeEntryTemplate" DataType="{x:Type local:WorkNarrativeEntryViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="19" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!-- 点和线共用同一个 7px 锚点，避免奇数宽元素在 22px 列内分别取整后错开 1px。 -->
                <Grid Grid.Row="0" Grid.Column="0" Width="7" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Rectangle Grid.Row="0"
                               Width="1"
                               Fill="{Binding IncomingConnectorBrush}"
                               Visibility="{Binding IncomingConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                    <Rectangle Grid.Row="1"
                               Width="1"
                               Fill="{Binding ConnectorBrush}"
                               Visibility="{Binding ConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                    <Ellipse Grid.RowSpan="2"
                              Style="{StaticResource RuntimeStepPulse}"
                              Fill="{Binding Step.NodeBrush}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                              Panel.ZIndex="2" />
                </Grid>
                <Grid Grid.Row="1" Grid.Column="0" Width="7" HorizontalAlignment="Center">
                    <Rectangle Width="1"
                               Fill="{Binding ConnectorBrush}"
                               Visibility="{Binding ConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                </Grid>
                <Grid Grid.Row="2" Grid.Column="0" Width="7" HorizontalAlignment="Center">
                    <Rectangle Width="1"
                               Fill="{Binding ConnectorBrush}"
                               Visibility="{Binding ConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                </Grid>
                <DockPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" LastChildFill="True" VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Visibility="{Binding BadgeVisibility}"
                                    Background="{Binding Step.StatusBadgeBackground}"
                                    BorderBrush="{Binding Step.StatusBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="6,1"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{Binding Step.StatusLabel}" Foreground="{Binding Step.StatusBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="9.5" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{Binding Step.AgentLabel}" Visibility="{Binding Step.AgentVisibility}" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="10.5" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding Step.Title}"
                                   Foreground="{DynamicResource FantasyCopperBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                </DockPanel>
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding Step.Detail}"
                           Visibility="{Binding Step.DetailVisibility}"
                           Foreground="{Binding Step.DetailBrush}"
                           FontFamily="{Binding Step.DetailFont}"
                           FontSize="12.5"
                           LineHeight="19"
                           TextWrapping="Wrap"
                           Margin="8,4,0,0" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="WorkCallGroupTemplate" DataType="{x:Type local:WorkCallGroupViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="0" Grid.Column="0" Width="7" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Rectangle Grid.Row="0" Width="1" Fill="{Binding IncomingConnectorBrush}" Visibility="{Binding IncomingConnectorVisibility}" HorizontalAlignment="Center" />
                    <Rectangle Grid.Row="1" Width="1" Fill="{Binding ConnectorBrush}" Visibility="{Binding ConnectorVisibility}" HorizontalAlignment="Center" />
                    <Ellipse Grid.RowSpan="2" Style="{StaticResource RuntimeStepPulse}" Fill="{Binding NodeBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="2" />
                </Grid>
                <Rectangle Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Width="1" Fill="{Binding ConnectorBrush}" Visibility="{Binding ConnectorVisibility}" HorizontalAlignment="Center" />
                <Expander Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="1"
                          Style="{StaticResource WorkMessageExpander}"
                          IsExpanded="{Binding IsExpanded, Mode=OneWay}"
                          Margin="8,0,0,0"
                          Padding="0"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <DockPanel LastChildFill="True" Margin="2,0,0,0">
                            <TextBlock Text="{Binding TargetText}" Visibility="{Binding TargetVisibility}" DockPanel.Dock="Right" Foreground="{DynamicResource FantasyFaintTextBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="10.5" Margin="12,0,0,0" />
                            <TextBlock Text="{Binding HeaderText}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                        </DockPanel>
                    </Expander.Header>
                    <Border Background="{DynamicResource FantasyNeutralWashBrush}"
                            BorderBrush="{DynamicResource FantasyCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="11,9"
                            Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding Steps}" HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="5" Height="5" Fill="{Binding NodeBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1,6,0,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource FantasyTextBrush}" FontSize="11.5" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Detail}" Visibility="{Binding DetailVisibility}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="11.5" LineHeight="17" TextWrapping="Wrap" Margin="0,3,8,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding StatusLabel}" Visibility="{Binding StatusVisibility}" Foreground="{Binding StatusBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="9.5" Margin="8,1,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Expander>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="WorkCommandGroupTemplate" DataType="{x:Type local:WorkCommandGroupViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="0" Grid.Column="0" Width="7" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Rectangle Grid.Row="0"
                               Width="1"
                               Fill="{Binding IncomingConnectorBrush}"
                               Visibility="{Binding IncomingConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                    <Rectangle Grid.Row="1"
                               Width="1"
                               Fill="{Binding ConnectorBrush}"
                               Visibility="{Binding ConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                    <Ellipse Grid.RowSpan="2"
                             Style="{StaticResource RuntimeStepPulse}"
                             Fill="{Binding NodeBrush}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                              Panel.ZIndex="2" />
                </Grid>
                <Grid Grid.Row="1" Grid.Column="0" Width="7" HorizontalAlignment="Center">
                    <Rectangle Width="1"
                               Fill="{Binding ConnectorBrush}"
                               Visibility="{Binding ConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                </Grid>
                <Grid Grid.Row="2" Grid.Column="0" Width="7" HorizontalAlignment="Center">
                    <Rectangle Width="1"
                               Fill="{Binding ConnectorBrush}"
                               Visibility="{Binding ConnectorVisibility}"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="0" />
                </Grid>
                <Expander Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="1"
                          Style="{StaticResource WorkMessageExpander}"
                          IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                          Margin="8,0,0,0"
                          Padding="0"
                          HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <DockPanel LastChildFill="True" Margin="2,0,0,0">
                        <TextBlock Text="{Binding HeaderText}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                    </DockPanel>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding Invocations}" Visibility="{Binding InvocationsVisibility}" HorizontalContentAlignment="Stretch">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource FantasyNeutralWashBrush}"
                                        BorderBrush="{DynamicResource FantasyCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Margin="0,0,0,7"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="31" />
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" Background="{DynamicResource FantasySurfaceBrush}" LastChildFill="True" Margin="0">
                                            <Button DockPanel.Dock="Right"
                                                    Width="26"
                                                    Height="24"
                                                    Padding="0"
                                                    Style="{StaticResource TinyButton}"
                                                    Click="WorkCommandCopyButton_Click"
                                                    ToolTip="复制命令"
                                                    Margin="0,4,8,4"
                                                    AutomationProperties.Name="复制命令">
                                                <TextBlock Text="{x:Static local:SemanticIcons.Copy}" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                            </Button>
                                            <TextBlock Text="{Binding ShellLabel}" Foreground="{DynamicResource FantasyMutedBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </DockPanel>
                                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="10,8,10,7">
                                            <TextBlock Foreground="{DynamicResource FantasyTextBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="11.5" TextWrapping="NoWrap">
                                                <Run Text="{Binding PromptText, Mode=OneWay}" Foreground="{DynamicResource FantasyFaintTextBrush}" /><Run Text="{Binding CommandText, Mode=OneWay}" />
                                            </TextBlock>
                                        </ScrollViewer>
                                        <ScrollViewer Grid.Row="2"
                                                      Visibility="{Binding OutputVisibility}"
                                                      MaxHeight="150"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Padding="10,2,10,8">
                                            <TextBlock Text="{Binding CommandOutput}" Foreground="{DynamicResource FantasyMutedBrush}" FontFamily="{StaticResource MonoFontFamily}" FontSize="11" LineHeight="17" TextWrapping="NoWrap" />
                                        </ScrollViewer>
                                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0">
                                            <TextBlock Text="{Binding ResultGlyph}" Foreground="{Binding ResultBrush}" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ResultLabel}" Foreground="{Binding ResultBrush}" FontSize="10.5" Margin="5,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding AuxiliarySteps}" Visibility="{Binding AuxiliaryVisibility}" HorizontalContentAlignment="Stretch">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding BlockBackground}" BorderBrush="{Binding BlockBorder}" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource FantasyTextBrush}" FontSize="11.5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Detail}" Visibility="{Binding DetailVisibility}" Foreground="{Binding DetailBrush}" FontFamily="{Binding DetailFont}" FontSize="11.5" LineHeight="17" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </Expander>
            </Grid>
        </DataTemplate>

        <local:WorkEntryTemplateSelector x:Key="WorkEntryTemplateSelector"
                                         NarrativeTemplate="{StaticResource WorkNarrativeEntryTemplate}"
                                         CallTemplate="{StaticResource WorkCallGroupTemplate}"
                                         CommandTemplate="{StaticResource WorkCommandGroupTemplate}" />

        <DataTemplate DataType="{x:Type local:WorkChainViewModel}">
            <Grid Margin="{Binding Margin}"
                  HorizontalAlignment="Stretch"
                  Tag="{Binding Id}">
                <Border Style="{StaticResource AtelierConversationGlowRail}"
                        Margin="0"
                        Panel.ZIndex="2"
                        IsHitTestVisible="False" />
                <Expander HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Style="{StaticResource WorkMessageExpander}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0"
                          Margin="0"
                          IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="7" HorizontalAlignment="Center">
                                <Ellipse Style="{StaticResource RuntimeStepPulse}" Fill="{Binding StatusBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding ChainLabel}" Foreground="{DynamicResource FantasyCopperBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text=" · " Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="11" />
                                <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Background="{Binding StatusBadgeBackground}"
                                    BorderBrush="{Binding StatusBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="7,2"
                                    Margin="12,0,0,0">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="10.5" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Margin="0,13,0,0">
                        <Border Visibility="{Binding TextVisibility}" Background="Transparent" Padding="22,0,0,14">
                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12.5" LineHeight="19" TextWrapping="Wrap" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding Entries}"
                                      Visibility="{Binding StepsVisibility}"
                                      ItemTemplateSelector="{StaticResource WorkEntryTemplateSelector}"
                                      HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                        <DockPanel Visibility="{Binding SummaryVisibility}" Margin="22,0,0,2" LastChildFill="True">
                            <Ellipse Width="6" Height="6" Fill="{Binding StatusBrush}" DockPanel.Dock="Left" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SummaryText}" Foreground="{DynamicResource FantasyFaintTextBrush}" FontSize="11.5" />
                        </DockPanel>
                    </StackPanel>
                </Expander>
            </Grid>
        </DataTemplate>
</ResourceDictionary>
