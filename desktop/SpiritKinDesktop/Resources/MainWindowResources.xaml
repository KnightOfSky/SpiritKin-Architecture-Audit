                                                                  VerticalAlignment="Center"
                                                                  IsHitTestVisible="False" />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <Grid Background="Transparent" IsHitTestVisible="False">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter ContentSource="Header"
                                                          TextElement.Foreground="{DynamicResource FantasyPrimaryBrush}"
                                                          TextElement.FontWeight="SemiBold"
                                                          IsHitTestVisible="False" />
                                        <TextBlock x:Name="Chevron"
                                                   Grid.Column="1"
                                                   Text="›"
                                                   Foreground="{DynamicResource FantasySecondaryBrush}"
                                                   FontSize="13"
                                                   Width="16"
                                                   Height="18"
                                                   Margin="6,-6,0,0"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   LineStackingStrategy="BlockLineHeight"
                                                   LineHeight="18" />
                                    </Grid>
                                </ToggleButton>
                                <Border x:Name="ExpanderDivider"
                                        DockPanel.Dock="Top"
                                        Background="{DynamicResource FantasyBorderBrush}"
                                        Height="1"
                                        Margin="0,8,0,0"
                                        Visibility="Collapsed" />
                                <ContentPresenter x:Name="ExpandSite"
                                                  DockPanel.Dock="Bottom"
                                                  ContentSource="Content"
                                                  Margin="0,10,0,0"
                                                  Visibility="Collapsed" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="AtelierToolStream">
                                <Setter TargetName="Chevron" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ExpanderDivider" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Chevron" Property="Text" Value="⌄" />
                                <Setter TargetName="ExpandSite" Property="Margin" Value="0,12,0,0" />
                            </Trigger>
