<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <DataTemplate x:Key="ProjectManagementTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8" MinHeight="58">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="EventTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource FantasyPrimaryBrush}" CornerRadius="3" Opacity="0.55" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding Type}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ModuleManagementTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="10,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1"
                                     BorderBrush="{Binding StatusBrush}"
                                     BorderThickness="1"
                                    Background="{DynamicResource FantasyListAltBrush}"
                                    CornerRadius="999"
                                    Padding="7,2"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                            <Border Grid.Column="2"
                                    BorderBrush="{Binding HealthBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource FantasySurfaceBrush}"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding HealthLabel}" Foreground="{Binding HealthBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource FantasyTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding OwnerLine}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding EnterpriseLine}" Foreground="{DynamicResource FantasyFieldLabelBrush}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,8,0,0">
                            <Border BorderBrush="{Binding RiskBrush}" BorderThickness="1" Background="{DynamicResource FantasySurfaceBrush}" CornerRadius="999" Padding="7,2" Margin="0,0,6,4">
                                <TextBlock Text="{Binding RiskLabel}" Foreground="{Binding RiskBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                            <Border BorderBrush="{DynamicResource FantasyBorderBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="0,0,6,4">
                                <TextBlock Text="{Binding GovernanceLabel}" Foreground="{DynamicResource FantasyPrimaryBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                            <Border BorderBrush="{DynamicResource FantasyLineBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="0,0,6,4">
                                <TextBlock Text="{Binding ActionLine}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="11" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ModuleManagementActionTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="10,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding PriorityBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Type}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1"
                                    BorderBrush="{Binding PriorityBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource FantasySurfaceBrush}"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding PriorityLabel}" Foreground="{Binding PriorityBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding ModuleDisplay}" Foreground="{DynamicResource FantasyPrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding GovernanceMeta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource FantasyTextBrush}" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding OperatorDisplay}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowDefinitionTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="10,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,5,0,0">
                            <Border BorderBrush="{Binding StatusBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource FantasyListAltBrush}"
                                    CornerRadius="4"
                                    Padding="7,2"
                                    Margin="0,0,6,4"
                                    MaxWidth="130">
                                <TextBlock Text="{Binding Category}" Foreground="{DynamicResource FantasyPrimaryBrush}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            </Border>
                            <Border BorderBrush="{Binding StatusBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource FantasyListAltBrush}"
                                    CornerRadius="4"
                                    Padding="7,2"
                                    Margin="0,0,6,4"
                                    MaxWidth="130">
                                <TextBlock Text="{Binding SourceLabel}" Foreground="{Binding StatusBrush}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            </Border>
                        </WrapPanel>
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding NodeSummary}" Foreground="{DynamicResource FantasyTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" MaxHeight="44" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowNodeTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                        <Border BorderBrush="{Binding StatusBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource FantasyListAltBrush}"
                                CornerRadius="4"
                                Padding="7,2"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left"
                                MaxWidth="180">
                            <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </Border>
                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowSwimlaneTemplate">
            <Border Width="{Binding Width}"
                    Height="{Binding Height}"
                    BorderThickness="0,0,0,1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource FantasyCanvasBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource FantasyLineBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Key}" Value="agent_task"><Setter Property="Background" Value="{DynamicResource FantasyListAltBrush}" /></DataTrigger>
                            <DataTrigger Binding="{Binding Key}" Value="tool_call"><Setter Property="Background" Value="{DynamicResource FantasySuccessWashBrush}" /></DataTrigger>
                            <DataTrigger Binding="{Binding Key}" Value="review_gate"><Setter Property="Background" Value="{DynamicResource FantasyWarningWashBrush}" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                    <TextBlock Text="{Binding Title}"
                           Foreground="{DynamicResource FantasyMutedBrush}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="12,8,0,0" />
            </Border>
        </DataTemplate>
        <Style x:Key="WorkflowSwimlaneItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="0" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
        </Style>
        <Style x:Key="WorkflowGraphNodeItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
        </Style>
        <DataTemplate x:Key="WorkflowVersionTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="8,7">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="WorkflowTaskProgressTemplate">
            <Grid Height="28" Margin="0,0,0,5" ToolTip="{Binding Detail}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="74" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource FantasyTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <ProgressBar Grid.Column="1"
                             Value="{Binding Percent, Mode=OneWay}"
                             Maximum="100"
                             Height="8"
                             Foreground="{Binding Brush}"
                             Background="{DynamicResource FantasyProgressTrackBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding PercentText}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="{Binding StatusLabel}" Foreground="{Binding Brush}" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="SearchCapabilityTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="KnowledgeJobTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="GlobalSearchResultTemplate">
            <Border Padding="10,8" Margin="0,0,0,3" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border BorderBrush="{DynamicResource FantasyBorderBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="4" Padding="7,4" Height="26" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Scope}" Foreground="{DynamicResource FantasyPrimaryBrush}" FontSize="12" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ChangeTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="StatusEventTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="18" Height="18" CornerRadius="9" Background="{DynamicResource FantasyHoverBrush}" VerticalAlignment="Top">
                        <TextBlock Text="✓" Foreground="{DynamicResource FantasyPrimaryBrush}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Type}" Foreground="{DynamicResource FantasyTextBrush}" TextWrapping="Wrap" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="LogTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="AgentTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SkillTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DebugSummary}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SkillSourceTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="McpServerTemplate">
            <Border Style="{StaticResource ListCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding StatusBrush}" CornerRadius="3" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Border Grid.Column="1" BorderBrush="{Binding StatusBrush}" BorderThickness="1" Background="{DynamicResource FantasyListAltBrush}" CornerRadius="999" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding HealthLine}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="McpToolMappingTemplate">
            <Border Style="{StaticResource ListCardBorder}" Padding="9,8">
                <StackPanel>
                    <TextBlock Text="{Binding InternalToolName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Meta}" Style="{StaticResource MutedText}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource FantasyMutedBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>
</ResourceDictionary>
