# Runtime overrides read by backend.app.settings
SPIRIT_HOTWORD=Spirit
SPIRIT_KNOWLEDGE_BACKEND=embedding
SPIRIT_TEXT_PROVIDER=llamacpp
SPIRIT_TEXT_MODEL=qwen/qwen3.6-35b-a3b
SPIRITKIN_TEXT_BASE_URL=http://127.0.0.1:8080/v1
SPIRITKIN_TEXT_API_KEY=
SPIRIT_TEXT_MODE=balanced
SPIRIT_TEXT_TEMPERATURE=0.4
SPIRIT_TEXT_TOP_P=0.85
SPIRIT_TEXT_MAX_NEW_TOKENS=512
SPIRIT_VISION_PROVIDER=llamacpp
SPIRIT_VISION_MODEL=qwen/qwen3.6-35b-a3b
SPIRIT_VISION_BASE_URL=http://127.0.0.1:8080/v1
SPIRIT_VISION_API_KEY=
SPIRIT_VISION_MODE=default
SPIRIT_VISION_TEMPERATURE=0.0
SPIRIT_VISION_MAX_TOKENS=25

# Shared embedding service (knowledge retrieval and Avatar semantic reactions)
SPIRITKIN_EMBEDDING_PROVIDER=llamacpp
SPIRITKIN_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
SPIRITKIN_EMBEDDING_BASE_URL=http://127.0.0.1:8081/v1
SPIRITKIN_EMBEDDING_API_KEY=
SPIRITKIN_RERANKER_PROVIDER=llamacpp
SPIRITKIN_RERANKER_MODEL=qwen/qwen3.6-35b-a3b
SPIRITKIN_RERANKER_BASE_URL=http://127.0.0.1:8080/v1
SPIRITKIN_RERANKER_API_KEY=
SPIRITKIN_RERANKER_TIMEOUT_SECONDS=5
SPIRITKIN_RERANKER_COOLDOWN_SECONDS=30

# llama.cpp service manager. Paths may be absolute or relative to the repository root.
SPIRITKIN_LLAMA_CPP_SERVER=runtime/llama.cpp/current/llama-server.exe
SPIRITKIN_LLAMA_CPP_TEXT_MODEL=
SPIRITKIN_LLAMA_CPP_MMPROJ=
SPIRITKIN_LLAMA_CPP_EMBEDDING_MODEL=runtime/llama.cpp/models/nomic-embed-text-v1.5.Q4_K_M.gguf
SPIRITKIN_LLAMA_CPP_CONTEXT=8192
SPIRITKIN_LLAMA_CPP_PARALLEL=2
SPIRITKIN_AUTO_START_LLAMACPP=1
SPIRITKIN_AVATAR_SEMANTIC_THRESHOLD=0.42
SPIRITKIN_AVATAR_SEMANTIC_TIMEOUT=1.5
# Optional full iOS Avatar URL for HTTPS/WSS deployments. Use a dedicated
# read-only runtime credential, never the control-plane management token.
SPIRITKIN_IOS_AVATAR_URL=

# Speech voice selection. Custom consented voices will use the versioned voice
# profile contract in docs/voice_identity_and_ai_cover_plan.md.
SPIRITKIN_TTS_ENABLED=1
SPIRITKIN_TTS_PROVIDER=cosyvoice
SPIRITKIN_TTS_VOICE=Fairy
SPIRITKIN_TTS_FALLBACK_PROVIDER=edge_tts
SPIRITKIN_TTS_PROFILE_ID=spiritkin.primary.v1
SPIRITKIN_TTS_PROFILE_PATH=state/voice-profiles/spiritkin.primary.v1/profile.json
SPIRITKIN_TTS_BASE_URL=http://127.0.0.1:50000
SPIRITKIN_TTS_RATE=+0%
SPIRITKIN_TTS_VOLUME=0.95

# MCP remote transport behavior
SPIRITKIN_MCP_DYNAMIC_TOOL_REGISTRATION=0

# WeChat iLink Bot (disabled by default; requires a real bot token/id)
SPIRITKIN_WECHAT_ILINK_ENABLED=0
SPIRITKIN_WECHAT_ILINK_BOT_TOKEN=
SPIRITKIN_WECHAT_ILINK_BOT_ID=
SPIRITKIN_WECHAT_ILINK_USER_ID=
SPIRITKIN_WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
SPIRITKIN_WECHAT_ILINK_CREDENTIALS=
SPIRITKIN_WECHAT_ILINK_LONG_POLL_SECONDS=35
SPIRITKIN_WECHAT_ILINK_REQUEST_TIMEOUT_SECONDS=45
SPIRITKIN_WECHAT_ILINK_MAX_RETRY_DELAY_SECONDS=20

# SMTP email tool (disabled by default; sending still requires per-call confirmation)
SPIRITKIN_EMAIL_ENABLED=0
SPIRITKIN_EMAIL_SMTP_HOST=
SPIRITKIN_EMAIL_SMTP_PORT=465
SPIRITKIN_EMAIL_SMTP_SECURE=1
SPIRITKIN_EMAIL_SMTP_STARTTLS=1
SPIRITKIN_EMAIL_SMTP_USER=
SPIRITKIN_EMAIL_SMTP_PASSWORD=
SPIRITKIN_EMAIL_FROM=
SPIRITKIN_EMAIL_FROM_NAME=

# Container / docker-compose hints
# Optional Growth override. Images must use immutable repo@sha256 references;
# the runtime never pulls them automatically. Set enabled=0 to override config.
SPIRITKIN_GROWTH_SANDBOX_EXECUTION_ENABLED=
SPIRITKIN_GROWTH_SANDBOX_IMAGES=
TZ=Asia/Shanghai
DISPLAY=
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Notes
# 1. Copy this file to `.env` before local Docker/Compose runs if you need overrides.
# 2. Model selection is resolved on the backend; frontends should only pass preference/mode, not raw provider secrets.
# 3. `SPIRIT_HOTWORD` / `SPIRIT_KNOWLEDGE_BACKEND` / model and embedding env vars override `config/config.yaml`.
# 4. DISPLAY / NVIDIA_* are mainly for Linux desktop or GPU-enabled container scenarios.
# 5. MCP secrets are referenced by each server's `header_env` mapping; do not put bearer tokens in registry `headers`.
# Proactive suggestions remain advisory and never execute tools directly.
SPIRITKIN_PROACTIVE_ENABLED=1
SPIRITKIN_PROACTIVE_QUIET_START=22
SPIRITKIN_PROACTIVE_QUIET_END=8
SPIRITKIN_PROACTIVE_COOLDOWN_SECONDS=600
SPIRITKIN_PROACTIVE_DAILY_LIMIT=3
SPIRITKIN_PROACTIVE_MIN_VALUE=0.6
SPIRITKIN_PROACTIVE_ACTIVE_SESSION_SECONDS=45

# Persistent APScheduler 3.x job store.
SPIRITKIN_SCHEDULER_ENABLED=1
SPIRITKIN_SCHEDULER_PATH=state/scheduler/jobs.sqlite3
SPIRITKIN_SCHEDULER_MISFIRE_GRACE_SECONDS=60
SPIRITKIN_SCHEDULER_MAX_INSTANCES=1

# Local music playback. Roots are separated by the platform path separator.
SPIRITKIN_MUSIC_ROOTS=
SPIRITKIN_MUSIC_COMMAND_PATH=state/music/commands.jsonl
# Remote media stays off unless the operator enables it and confirms the network tool.
SPIRITKIN_MUSIC_REMOTE_URLS=0

# Game automation ships with no active adapters. Explicitly allow only controlled local/test adapters.
SPIRITKIN_GAME_ADAPTER_ROOT=config/game_automation/adapters
SPIRITKIN_GAME_ADAPTER_ALLOWLIST=
SPIRITKIN_GAME_AUDIT_ROOT=state/game_automation/audit
